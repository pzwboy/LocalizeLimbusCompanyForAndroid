{
    "dataList": [
        {
            "id": "get_10214_1",
            "desc": "獲得人格",
            "dlg": "宁可能対指令之意抱有好奇心。不過即使有疑問也必須執行指令。指令是絶対的，因此只需執行。"
        },
        {
            "id": "lobby_morning_10214_1",
            "desc": "早間問候",
            "dlg": "于早晨飲用一升果汁。在跟随代行者出発之前，充分活動身体。這是期限為无限的指令，我一直在執行之中。"
        },
        {
            "id": "lobby_noon_10214_1",
            "desc": "午間問候",
            "dlg": "……時間到了。期限是正午之前。……很遺憾，我要剪掉我昨日見到的第五个人，也就是袮的左耳耳垂。\n我不建議袮反抗。在那種情况下，通常会有管制范圍更大的新指令下達。"
        },
        {
            "id": "lobby_night_10214_1",
            "desc": "晚間問候",
            "dlg": "“斬開三次后巷夜晚的街道之光。期限為半年。”……我仍在煩悩該以何種方式執行這条指令。\n所以我每晚都徘徊于霓虹灯下的街巷，冥思苦想着。"
        },
        {
            "id": "smalltalk_10214_1",
            "desc": "対話 1",
            "dlg": "指令之意便是都市之意，都市之意便是指令之意。也許真的是這様，但正如遵从指令并不需要浮士德去理解一様，也没有必要理解指令之意。執行它的价値在于其本身。"
        },
        {
            "id": "smalltalk_10214_2",
            "desc": "対話 2",
            "dlg": "有時会覚得指令和浮士德非常相似。指令通過傳令員不停地穿梭于都市各地，令人不由得想起曾為追尋好奇心而奔走的過往。\n現在是時候譲那様的瞬間停止了。只要遵循指令，便自然能明悟都市之意。"
        },
        {
            "id": "smalltalk_10214_3",
            "desc": "対話 3",
            "dlg": "知識的積累与理解這様的行為，在都市中最終是没有意義的這件事，浮士德似乎无法理解。\n也許正因如此，他們才一直試圖剥奪我的訪問権限……但其嘗試都以失敗告終。這大概也是指令之意所致叭。"
        },
        {
            "id": "smalltalk_10214_4",
            "desc": "同步后対話 1",
            "dlg": "人們通常都是用食指去指向某些東西。食指之所以為食指，是因為指令指引我們去往應去之処。\n這一切并非偶然所致。即便有人結成朋党去抵抗指令，也是指令之意的一部分。"
        },
        {
            "id": "smalltalk_10214_5",
            "desc": "同步后対話 2",
            "dlg": "対被賦予代行者或是傳令員那様的身分，我并不期待。那種事情不是由浮士德的意志所决定的。\n无論是将現在這些人斬殺也好，還是接受指令也罷。无論被賦予食指的那種身分，都没有区別。"
        },
        {
            "id": "neglect_10214_1",
            "desc": "閑置",
            "dlg": "唔。通過多面鏡而産生的光的分裂……這似乎并不是対那条指令的合适解釋。"
        },
        {
            "id": "gacksung_10214_1",
            "desc": "進行同步",
            "dlg": "新的指令。“斬首7名刀刃横在脖頸上時仍不放弃反抗的后巷居民。”人数与袮們相符。那么，開始執行。"
        },
        {
            "id": "formation_10214_1",
            "desc": "人格出戦",
            "dlg": "接到了指令。"
        },
        {
            "id": "battleentry_10214_1",
            "desc": "進入戦斗",
            "dlg": "前往指令所指示之処。"
        },
        {
            "id": "battle_select_10214_1",
            "desc": "戦斗中選中人格",
            "dlg": "進行対話并不違背指令。"
        },
        {
            "id": "battle_endcommand_10214_1",
            "desc": "進行攻撃",
            "dlg": "遵从指令，斬撃。"
        },
        {
            "id": "battle_enemy_break_10214_1",
            "desc": "敵方混乱",
            "dlg": "請稍候，還需再将袮斬裂五次。"
        },
        {
            "id": "battle_break_10214_1",
            "desc": "自身混乱",
            "dlg": "唔……"
        },
        {
            "id": "battle_kill_10214_1",
            "desc": "撃殺敵方",
            "dlg": "執行完畢。"
        },
        {
            "id": "battle_dead_10214_1",
            "desc": "自身陣亡",
            "dlg": "没有引向死亡的指令麼……那么……這是……誰的，意志……"
        },
        {
            "id": "choice_success_p_10214_2",
            "desc": "判定成功",
            "dlg": "完成了。"
        },
        {
            "id": "choice_fail_n_10214_1",
            "desc": "判定失敗",
            "dlg": "這是由指令所導向的失敗。"
        },
        {
            "id": "battle_clear_10214_1",
            "desc": "戦斗勝利",
            "dlg": "那些没有履行指令的人們正在被依序清理。“剪下663縷頭発放入信封中并投入3号檢票口”的執行只是略有差池……无須担心。"
        },
        {
            "id": "battle_clear_ex_10214_1",
            "desc": "EX CLEAR戦斗勝利",
            "dlg": "指令已被執行。没有任何為其苦悩的必要，由于指令明確，執行起来也非常簡便。雖然対抗我們的人很多，但正如袮所見，那是毫无意義的。"
        },
        {
            "id": "battle_defeat_10214_1",
            "desc": "戦斗失敗",
            "dlg": "……我不認為這是指令的失敗。失敗的只是我自己。我的失敗也在指令的計劃之中。很快就会有苦行者或代行者来代替我，失敗的我只会从都市中消失。\n這其中所有的結果，都是指令所指示的方向叭。"
        }
    ]
}