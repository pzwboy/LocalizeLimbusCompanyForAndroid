{
    "dataList": [
        {
            "id": "announcer_cheer_41_1",
            "dlg": "媽媽每次拿着刀离開的時候，我真正害怕的是……他不会再回来。\n袮們捏？能平安无事地回来麼？還是会変成像媽媽一様的騙子捏？",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_cheer_41_2",
            "dlg": "夜良秀苦！（よりょしゅく！）\n媽媽不喜歓“初見指教”，所以我就帮他想了這種問候方式。是良秀哦，夜良秀苦！",
            "imgStr": "PinkyChibi_announcer_1"
        },
        {
            "id": "announcer_specialcheer_41_1",
            "dlg": "……袮不是為了死在這種地方，才离開蜘蛛巢的叭。",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_specialcheer_41_2",
            "dlg": "真的只有這些了麼？\n如果記憶中所残留的感情是真的，就不應該在這種地方那么難看地死去叭。",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_enemy_break_41_1",
            "dlg": "半吊子的怜憫，只会帯来不必要的痛苦。\n若袮想要收割生命，就把他們的頭坎下来。",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_ally_break_41_1",
            "dlg": "這種時候要説，没保護好袮真是“歉抱”。",
            "imgStr": "PinkyChibi_announcer_1"
        },
        {
            "id": "announcer_ally_break_41_2",
            "dlg": "没有比“没有保護好袮真是抱歉”更空洞的話語了。那句話説到底就是没能守住的意思。",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_killenemy_41_1",
            "dlg": "袮們所應走的修羅道，依旧遠得看不見尽頭……還会変得更加遥遠。",
            "imgStr": "PinkyChibi_announcer_4"
        },
        {
            "id": "announcer_ally_dead_41_1",
            "dlg": "雖然看不見、也抓不到。但只要那鎖鏈仍将袮們相連……袮們的時間就不会消失。",
            "imgStr": "PinkyChibi_announcer_4"
        },
        {
            "id": "announcer_enemy_adv_41_1",
            "dlg": "是媽媽每次都用奇怪的縮写形容的那種情况。万短至藝。袮們，都被切成兩半了捏。",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_ally_adv_41_1",
            "dlg": "也許曾有過那么一天。我比媽媽先到家的那様的一天。\n放学回到家后，听到門后傳来的媽媽的脚步声……只是那个声音就足劬譲我開心了。",
            "imgStr": "PinkyChibi_announcer_2"
        },
        {
            "id": "announcer_ally_adv_41_2",
            "dlg": "很快就会結束叭。……看到這些我反而覚得，縮略的藝術是看不到結束的母親所能選擇的，最好的方法。\n无論是在蜘蛛巢中的生活，還是我本應經暦的等待……他大概想把它們都短暫、快速地全部斬断叭。",
            "imgStr": "PinkyChibi_announcer_4"
        },
        {
            "id": "announcer_ally_advex_41_1",
            "dlg": "并没有被斬断。只是交織、糾纏在一起罷了。重新接續的絲綫，仍握在袮們的手中。",
            "imgStr": "PinkyChibi_announcer_4"
        },
        {
            "id": "announcer_ally_advex_41_2",
            "dlg": "要放弃了麼？別那么做。若輕易将手放開的話……總有一天会后悔的。",
            "imgStr": "PinkyChibi_announcer_2"
        },
        {
            "id": "announcer_danger_41_1",
            "dlg": "這様就可以了麼？没有忘記什么叭？\n……如果不想再在這令人憎惡的地方待下去，就把一切都妥善地終結掉叭。徹底到連一絲留恋都不剩。",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_enemy_specialskill_41_1",
            "dlg": "呀。能看見麼？不管怎么看都很危険叭……啊！要我告訴袮能藏起来的地方麼？",
            "imgStr": "PinkyChibi_announcer_1"
        },
        {
            "id": "announcer_enemy_specialgimmick_41_1",
            "dlg": "復雑纏結的問題，要找到其起始与終結才能解决。\n若是做不到的話，就干脆全部切断，連形体也不要残留。",
            "imgStr": "PinkyChibi_announcer_4"
        },
        {
            "id": "announcer_advatk_physical_41_1",
            "dlg": "……媽媽精通任何武器。其中最為出色的就是刀。",
            "imgStr": "PinkyChibi_announcer_2"
        },
        {
            "id": "announcer_disadvatk_physical_41_1",
            "dlg": "明白了。這種東西，学校是不会教的。",
            "imgStr": "PinkyChibi_announcer_2"
        },
        {
            "id": "announcer_disadvatk_physical_41_2",
            "dlg": "不管怎么教他，每次説縮略語的時候都很奇怪。現在更厳重了。",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_advatk_attr_41_1",
            "dlg": "……姿勢没有変形捏。",
            "imgStr": "PinkyChibi_announcer_4"
        },
        {
            "id": "announcer_disadvatk_attr_41_1",
            "dlg": "真是的！我説過不能那么做拉！",
            "imgStr": "PinkyChibi_announcer_1"
        },
        {
            "id": "announcer_disadvatk_attr_41_2",
            "dlg": "埃。不能那么做，我説過了。",
            "imgStr": "PinkyChibi_announcer_4"
        },
        {
            "id": "announcer_enemy_specialbuff_41_1",
            "dlg": "有人生气的時候……要躱起来，不能譲人听到呼吸声。\n呼……",
            "imgStr": "PinkyChibi_announcer_1"
        },
        {
            "id": "announcer_enemy_specialdebuff_41_1",
            "dlg": "那家夥……被漂亮地纏進蜘蛛网里了。",
            "imgStr": "PinkyChibi_announcer_4"
        },
        {
            "id": "announcer_ally_specialbuff_41_1",
            "dlg": "并不期望收到的礼物有時也会有帮助。\n就像換成了和媽媽同様顔色的，我的義眼一様。",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_ally_specialbuff_41_2",
            "dlg": "无法實現的希望也好，墜落不留痕迹的希望也罷……都是我所期望的。\n就像敵人給的帮助也算得上是帮助叭。",
            "imgStr": "PinkyChibi_announcer_4"
        },
        {
            "id": "announcer_ally_specialdebuff_41_1",
            "dlg": "有什么堅靭的東西粘在了袮身上。要切断它的方法……袮明白的叭？",
            "imgStr": "PinkyChibi_announcer_4"
        },
        {
            "id": "announcer_enemy_destroy_41_1",
            "dlg": "被片片切落，連形体都没有残留。就像媽媽被千刀万刳的記憶一様。",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_enemy_destroy_41_2",
            "dlg": "会覚得自己也像那些碎片一様，是忘却也无所謂的无足輕重的記憶。\n若早知道那些珍貴的記憶也会消失的話，我的這分怨恨……或許也会少上一些叭。",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_round_takebigdmg_41_1",
            "dlg": "啊啊！？明明剛剛那么自信満満地冲上去……原来只是“試就逝”那種感覚麼？",
            "imgStr": "PinkyChibi_announcer_1"
        },
        {
            "id": "announcer_round_takebigdmg_41_2",
            "dlg": "咳咳。“不評”。剛剛的我会当作没看見的！",
            "imgStr": "PinkyChibi_announcer_1"
        },
        {
            "id": "announcer_round_givebigdmg_41_1",
            "dlg": "嗚哇~現在看起来完全就像叔叔和阿姨們一様！",
            "imgStr": "PinkyChibi_announcer_1"
        },
        {
            "id": "announcer_round_givebigdmg_41_2",
            "dlg": "小時候不明白。為什么媽媽連我和那些叔叔們説話都不允許。\n那些外聘講師……那怕在手指之中，也算是屈指可数的高手。他們会教媽媽和袮們所展示的相似，甚至更歴害的技術。",
            "imgStr": "PinkyChibi_announcer_2"
        },
        {
            "id": "announcer_multikillenemy_41_1",
            "dlg": "若要為袮們別上一朶花的話，彼岸花最合适。最鮮紅的……地獄色的彼岸花。",
            "imgStr": "PinkyChibi_announcer_3"
        },
        {
            "id": "announcer_battle_win_41_1",
            "dlg": "就像現在這様，和媽媽一起去各種各様的地方，積累許多回憶叭。\n為了總有一天……他能把我帯去其中最棒的那个地方。",
            "imgStr": "PinkyChibi_announcer_1"
        },
        {
            "id": "announcer_battle_defeat_41_1",
            "dlg": "没関系！再来一次就好拉！",
            "imgStr": "PinkyChibi_announcer_1",
            "playWeight": 0.7
        },
        {
            "id": "announcer_battle_defeat_41_2",
            "dlg": "只是這種程度，就覚得前路被断絶了麼？\n不。袮們的流向，那条相連的絲綫……比袮們想象的更為堅靭。",
            "imgStr": "PinkyChibi_announcer_4",
            "playWeight": 0.3
        },
        {
            "id": "announcer_equip_41_1",
            "dlg": "有滴答滴答的鐘表，還有布隆布隆的巴士。還交了一堆很棒的朋友捏！\n嘿嘿。太好拉。即使我消失了，也不会只剩媽媽一个人拉。",
            "imgStr": "PinkyChibi_announcer_1"
        }
    ]
}