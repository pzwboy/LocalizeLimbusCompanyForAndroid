{
    "dataList": [
        {
            "id": 0,
            "place": "阿戈尓，梅厄斯的家",
            "model": "과거메이어스",
            "content": "戦况正在惡化。"
        },
        {
            "id": 1,
            "model": "과거메이어스",
            "content": "恐魚們正在蜂擁而至。"
        },
        {
            "id": 2,
            "model": "과거메이어스",
            "content": "這是倣佛随時能奔向星海的阿戈尓的発展，随着海灾的到来而沈没的那一天。"
        },
        {
            "id": 3,
            "teller": "研究員同僚",
            "title": "阿戈尓",
            "content": "不去陸地上麼，梅厄斯？最近因為感到不安而离開阿戈尓的人可不少。"
        },
        {
            "id": 4,
            "model": "과거메이어스",
            "content": "我不去。如果阿戈尓崩潰，陸上最終也不会平安无事。"
        },
        {
            "id": 5,
            "model": "과거메이어스",
            "content": "為什么這么問？袮准備去麼？"
        },
        {
            "id": 6,
            "teller": "研究員同僚",
            "title": "阿戈尓",
            "content": "正在考慮中。"
        },
        {
            "id": 7,
            "model": "과거메이어스",
            "content": "雖然人数并不多，但周圍的人們開始一个接一个地前往陸地。"
        },
        {
            "id": 8,
            "model": "과거메이어스",
            "content": "其中有些和我関系很好的人，都勧我和他們一起前往陸地……"
        },
        {
            "id": 9,
            "model": "과거메이어스",
            "content": "但我不愿抛下陷于危机的故郷逃走。"
        },
        {
            "id": 10,
            "model": "과거메이어스",
            "content": "預料之中的灾難，降臨了。"
        },
        {
            "id": 11,
            "model": "과거메이어스",
            "content": "雖然阿戈尓也遭受了巨大的損失，但受損最大的還是陸地。"
        },
        {
            "id": 12,
            "model": "과거메이어스",
            "content": "听到那些消息的我……想要帮助他們。"
        },
        {
            "id": 13,
            "model": "과거메이어스",
            "content": "我要前往陸地。"
        },
        {
            "id": 14,
            "teller": "研究員同僚",
            "title": "阿戈尓",
            "content": "真的要去麼？再考慮一下叭。現在离開的話，今后可能很難再回来了！"
        },
        {
            "id": 15,
            "content": "与我不同，他們想要平安度過一天都很艱難……"
        },
        {
            "id": 16,
            "content": "稍微有些余裕的我，應該給他們提供帮助才対叭。"
        },
        {
            "id": 17,
            "model": "과거메이어스",
            "content": "我明白。但如果現在不去帮帮他們的話……大量的陸地人将暴露于危険之中。"
        },
        {
            "id": 18,
            "teller": "研究員同僚",
            "title": "阿戈尓",
            "content": "……那危険或許也会傷害到袮。"
        },
        {
            "id": 19,
            "model": "과거메이어스",
            "content": "即便如此，我也想去帮助他們。"
        },
        {
            "id": 20,
            "model": "과거메이어스",
            "content": "為了前往陸地，我低价購入了一艘阿戈尓的科研船。"
        },
        {
            "id": 21,
            "model": "과거메이어스",
            "content": "這艘船在停泊状態之外甚至无法潜航……若是平時的我，対它根本不屑一顧。"
        },
        {
            "id": 22,
            "model": "과거메이어스",
            "content": "……但我想它至少能為我在陸地和近海移動提供很大的帮助。"
        },
        {
            "id": 23,
            "model": "과거메이어스",
            "content": "我所……未曾預見到的是。"
        },
        {
            "id": 24,
            "place": -1,
            "model": "과거메이어스",
            "content": "我登上陸地后初次所見的是……"
        },
        {
            "id": 25,
            "model": "과거메이어스",
            "content": "対阿戈尓人的，无尽的敵意。"
        },
        {
            "id": 26,
            "model": "과거메이어스",
            "content": "只是因為我与海嗣来自同一片大海，"
        },
        {
            "id": 27,
            "model": "과거메이어스",
            "content": "就将身為阿戈尓人的我所伸出的手、心与研究拒之門外。"
        },
        {
            "id": 28,
            "teller": "村民",
            "title": "伊比利亞",
            "content": "立刻从村子离開！"
        },
        {
            "id": 29,
            "teller": "村民",
            "title": "伊比利亞",
            "content": "我們不需要袮那種研究……我們該如何去相信袮這个与灾厄同出一処的人？"
        },
        {
            "id": 30,
            "model": "과거메이어스",
            "content": "帯来的触媒被他們没收，研究資料遭到撕毀。"
        },
        {
            "id": 31,
            "model": "과거메이어스",
            "content": "共同抵御灾厄的愿望，在因灾厄而孳生的敵意的呑噬之下消失殆尽。"
        },
        {
            "id": 32,
            "model": "과거메이어스",
            "content": "在那之后，我曾釋出的那分善意又変成了更大的敵意与懐疑。"
        },
        {
            "id": 33,
            "content": "是凄惨的境遇譲他們変成這様，還是他們本性就是如此？"
        },
        {
            "id": 34,
            "content": "不久之后，以“可疑”為理由，我从阿戈尓帯来的科研船被搶走了……"
        },
        {
            "id": 35,
            "model": "과거메이어스",
            "content": "数周之后，我再次在海岸見到那艘科研船時，它的舷側被刻上了“大衆的反叛”作為名字，听起来像是那儿缺了个螺絲一様躄脚。"
        },
        {
            "id": 36,
            "model": "과거메이어스",
            "content": "直到那時我也仍未停止……為了陸地人們而進行的研究。"
        },
        {
            "id": 37,
            "model": "과거메이어스",
            "content": "為了尋求更有效地抑制海嗣進化的手段、拯救伊比利亞被溟痕汚染的土壤，我進行了数百次的試錯。"
        },
        {
            "id": 38,
            "model": "과거메이어스",
            "content": "但都毫无進展……"
        },
        {
            "id": 39,
            "model": "과거메이어스",
            "content": "直到我看着審判庭的人一个个地抓走阿戈尓人的那一天。"
        },
        {
            "id": 40,
            "content": "突然，正在研究的恐魚標本和資料映入了我的眼帘。"
        },
        {
            "id": 41,
            "content": "不同的外形、相異的結構。即便如此，対它們而言彼此之間仍是“我們”，而非是“我”。"
        },
        {
            "id": 42,
            "content": "我対阻止它們的進化第一次産生了質疑。"
        },
        {
            "id": 43,
            "place": "梅厄斯的心象迷宮",
            "model": "돈키호테",
            "content": "他対吾等所説……并非全是虚言。",
            "teller": "堂吉訶德",
            "title": "3号罪人"
        },
        {
            "id": 44,
            "model": "아이린",
            "content": "既然梅厄斯是深海教会的主教，那无論情况如何，在審判庭之上，他都只能是罪犯。"
        },
        {
            "id": 45,
            "model": "뒤틀린메이어스",
            "content": "我越研究下去……海嗣是一種過于利他的存在這一事實就愈発清晰。"
        },
        {
            "id": 46,
            "model": "뒤틀린메이어스",
            "content": "対它們来説重要的事物只有存在的延續。从它們的行為中感受不到絲毫的自私。"
        },
        {
            "id": 47,
            "model": "뒤틀린메이어스",
            "content": "它們并非生活在海中的邪惡怪物。"
        },
        {
            "id": 48,
            "model": "아이린",
            "content": "……"
        },
        {
            "id": 49,
            "model": "아이린",
            "content": "梅厄斯，也許正如袮所説……海嗣并不是邪惡的。"
        },
        {
            "id": 50,
            "model": "아이린",
            "content": "但不管它們是善意的生命体還是其他的文明形態……這不会有什么改変。"
        },
        {
            "id": 51,
            "model": "아이린",
            "content": "……伊比利亞与審判庭并没有将海嗣定義為邪惡。"
        },
        {
            "id": 52,
            "model": "아이린",
            "content": "海嗣是我們的敵人。"
        },
        {
            "id": 53,
            "model": "아이린",
            "content": "是人類的威脅。"
        },
        {
            "id": 54,
            "model": "아이린",
            "content": "身為審判官的我，所能説的只有一句話。"
        },
        {
            "id": 55,
            "model": "아이린",
            "content": "袮，以及袮們，都是敵人。"
        },
        {
            "id": 56,
            "model": "뒤틀린메이어스",
            "content": "……"
        },
        {
            "id": 57,
            "model": "뒤틀린메이어스",
            "content": "……我去了都市的話，対審判庭而言会是个好消息叭。"
        },
        {
            "id": 58,
            "model": "아이린",
            "content": "為什么覚得把我們的問題抛給其他世界，対審判庭而言会是件好事捏？"
        },
        {
            "id": 59,
            "model": "아이린",
            "content": "那是……対我們自尊的背弃。"
        },
        {
            "id": 60,
            "model": "아이린",
            "content": "若是他們——那些生活在都市的人們允許也就罷了……但作為審判官，我不能対這種不了了之的処理坐視不管。"
        },
        {
            "id": 61,
            "model": "이스마엘",
            "content": "我們是不会允許的。",
            "teller": "以實瑪利",
            "title": "8号罪人"
        },
        {
            "id": 62,
            "model": "이스마엘",
            "content": "无論用怎様的善意作為包装，梅厄斯的航路……也并非我想前往的方向。",
            "teller": "以實瑪利",
            "title": "8号罪人"
        },
        {
            "id": 63,
            "content": "望着対以實瑪利的話表示賛同、做好了戦斗准備的罪人們，梅厄斯遺憾地低声道。"
        },
        {
            "id": 64,
            "model": "뒤틀린메이어스",
            "content": "……我本不想這様的。"
        },
        {
            "id": 65,
            "content": "浪潮。"
        },
        {
            "id": 66,
            "content": "可以称之為浪潮的恐魚群席卷而来。"
        },
        {
            "id": 67,
            "model": "박사",
            "content": "但，也只能這様了。"
        },
        {
            "id": 68,
            "model": "박사",
            "content": "袮的話語之中……尽是袮自己的顔色。"
        },
        {
            "id": 69,
            "model": "박사",
            "content": "但丁經理……対叭。"
        },
        {
            "id": 70,
            "model": "파우스트",
            "content": "請講。",
            "teller": "浮士德",
            "title": "2号罪人"
        },
        {
            "id": 71,
            "model": "박사",
            "content": "我們来阻止从后方涌来的恐魚群。"
        },
        {
            "id": 72,
            "model": "박사",
            "content": "在這期間……袮們能負責鎮圧梅厄斯和其余的恐魚麼？"
        },
        {
            "id": 73,
            "model": "단테",
            "content": "<当然。>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 74,
            "model": "파우스트",
            "content": "經理表示可行，給出了肯定的答復。",
            "teller": "浮士德",
            "title": "2号罪人"
        },
        {
            "id": 75,
            "model": "박사",
            "content": "全体干員，引誘恐魚群。"
        },
        {
            "id": 76,
            "model": "박사",
            "content": "没有剿滅它們的必要。我們的目標是……不譲那浪潮波及到辺獄公司的人。"
        },
        {
            "id": 77,
            "model": "박사",
            "content": "艾麗倪，我也想請袮帮我這个忙，阿米亞也是一様……"
        },
        {
            "id": 78,
            "model": "박사",
            "content": "為了以防万一，請支援辺獄公司。"
        },
        {
            "id": 79,
            "model": "아미야",
            "content": "……好的！那么就按照作戦規劃……開始任務。"
        }
    ]
