{
    "dataList": [
        {
            "id": 0,
            "model": "싱클레어",
            "content": "那天是圣誕節，鎮上充斥着鐘声与喜悦。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 1,
            "model": "싱클레어",
            "content": "在圣夜的祝福下，我本打算回去向家人們坦白自己的行為。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 2,
            "model": "싱클레어",
            "content": "尽管我犯下了偸取地下室的鑰匙這種愚蠢的錯誤，但我還是想重新做回他們的模范儿子。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 3,
            "model": "싱클레어",
            "content": "在那期間，我備受煎熬，并恐惧不已。我切實領悟到了自己所在的世界究竟是多么地和平，多么地令人満足。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 4,
            "model": "싱클레어",
            "content": "這様一来，雖然家人們應該最開始会有些吃驚，但肯定很快就会歓迎我回到那个樂园的叭。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 5,
            "model": "싱클레어",
            "content": "肯定，是這様的叭。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 6,
            "model": "싱클레어",
            "content": "但是。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 7,
            "model": "싱클레어",
            "content": "唔……？",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 8,
            "model": "싱클레어",
            "content": "平日里，我一站到正門前就能听見迎接我的机器狗的叫声，但如今，家只是被寂静的夜色包裹着。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 9,
            "model": "싱클레어",
            "content": "而后我所面対的，是一个已然滅亡的樂园。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 10,
            "teller": "姐姐",
            "title": "我的家人",
            "content": "辛克莱……快……逃……"
        },
        {
            "id": 11,
            "teller": "父親",
            "title": "我的家人",
            "content": "辛……辛克……辛、辛、辛辛辛……"
        },
        {
            "id": 12,
            "model": "싱클레어",
            "content": "有人匝碎了父親的頭。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 13,
            "model": "싱클레어",
            "content": "是个身着生鏽的銀色奎甲的怪異人物。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 14,
            "teller": "？？？",
            "title": "記憶中的那人",
            "content": "非人之物居然会因為仰慕人性而濫発虚假的感情。"
        },
        {
            "id": 15,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "別管了，圭多。那是不純之物特有的生存本能在作祟。"
        },
        {
            "id": 16,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "不……應該説只是害怕被関机叭。哈哈！"
        },
        {
            "id": 17,
            "model": "싱클레어",
            "content": "机械的碎片、血和肉，飛濺到空中，而后散落到地上。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 18,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "辛克莱！袮来了呀！！！"
        },
        {
            "id": 19,
            "model": "싱클레어",
            "content": "啊……啊……",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 20,
            "model": "싱클레어",
            "content": "克羅默拿着一把沾満血肉的錘子靠了過来。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 21,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "啊，這个啊？"
        },
        {
            "id": 22,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "我啊，从以前開始，就无法忍受和那些骯臓的家夥有任何的牽連。"
        },
        {
            "id": 23,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "畢竟我是愛着人類的博愛主義者啊！"
        },
        {
            "id": 24,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "但如果連那些不浄的家夥們的孩子也是這様的話……"
        },
        {
            "id": 25,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "我該怎么処置袮捏，辛克莱？唔？"
        },
        {
            "id": 26,
            "model": "싱클레어",
            "content": "我的腿已經脱力了。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 27,
            "model": "싱클레어",
            "content": "嘴也是。感覚全身上下都不听使喚。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 28,
            "model": "싱클레어",
            "content": "克羅默的脚就在我的眼前。但我却无論如何也抬不起頭。直到他离我如此之近，我才終于害怕起来，緊緊地閉上了双眼。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 29,
            "model": "싱클레어",
            "content": "一想到那个沾有父母和姐姐的肉片的鉄錘即将向我匝来，我就无法抑制住内心的恐惧。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 30,
            "model": "싱클레어",
            "content": "……",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 31,
            "model": "싱클레어",
            "content": "然而，完全没有要発生什么的迹象。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 32,
            "model": "싱클레어",
            "content": "感到不可思議的我，戦戦兢兢地睜開眼、抬起頭来。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 33,
            "model": "싱클레어",
            "content": "克羅默正訂着我。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 34,
            "model": "싱클레어",
            "content": "他露出了一个完美的笑容，就像曾几何時，我坐在課棹前，他告訴我他的名字并搭話的時候一様。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 35,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "但袮是我的英雄捏，辛克莱。"
        },
        {
            "id": 36,
            "model": "싱클레어",
            "content": "接着，他伸手从我的校服襯衫口袋中取出了一枚硬幣。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 37,
            "model": "싱클레어",
            "content": "是我拿着的兩枚硬幣中的一枚。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 38,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "从今往后……袮将懐疑一切，担憂一切……一辺不断地想起我，一辺懐揣着恐惧就這么活下去叭。"
        },
        {
            "id": 39,
            "model": "싱클레어",
            "content": "嗚……嗚嗚……",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 40,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "然后，等時机到了……我就会呼喚袮的。"
        },
        {
            "id": 41,
            "model": "학생크로머",
            "teller": "克羅默",
            "title": "学生？",
            "content": "喂！把這孩子帯到安全的地方去！要是誰対他出手，我絶不饒恕。"
        },
        {
            "id": 42,
            "model": "싱클레어",
            "content": "在不断襲来的耳鳴声，靴子声，以及眩暈感中……",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 43,
            "model": "싱클레어",
            "content": "我就這様失去了意識。",
            "teller": "辛克莱",
            "title": "11号罪人"
        }
    ]
}