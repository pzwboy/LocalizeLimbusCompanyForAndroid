{
    "dataList": [
        {
            "id": 0,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢之刃",
            "content": "割舍叭。"
        },
        {
            "id": 1,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢之刃",
            "content": "一絲不留地斬断、焚尽一切。"
        },
        {
            "id": 2,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢之刃",
            "content": "将蜘蛛巢。"
        },
        {
            "id": 3,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢之刃",
            "content": "還有袮們。"
        },
        {
            "id": 4,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢之刃",
            "content": "尽数剖去。"
        },
        {
            "id": 5,
            "content": "我看見了那根綫。"
        },
        {
            "id": 6,
            "content": "那根我未能斬断、又必須斬断的綫，如今在我眼前清晰可見。"
        },
        {
            "id": 7,
            "content": "那些我不愿再面対的光景，也一同如海浪般向我涌来。"
        },
        {
            "id": 8,
            "content": "唯独那分不想回去的空洞心愿，像貝殻般留在原地，"
        },
        {
            "id": 9,
            "content": "糾纏的時間呑没了我的意識。"
        },
        {
            "id": 10,
            "content": "這里面没有日暦，但我知道過去了多少天。"
        },
        {
            "id": 11,
            "content": "即使没有時鐘，我也知暁現在是白天還是黑夜。"
        },
        {
            "id": 12,
            "content": "可是……為什么我一定要被関在保険箱里捏，為什么爸爸媽媽們想方設法地阻止我出去捏。"
        },
        {
            "id": 13,
            "content": "我唯独不明白這一点。"
        },
        {
            "id": 14,
            "content": "是在懲罰我麼？還是……他們不要我了？"
        },
        {
            "id": 15,
            "content": "我懐揣着這个永遠得不到解答的疑問。"
        },
        {
            "id": 16,
            "content": "雖然清楚這一切總有一天会迎来終結，可唯独无从知暁那一天何時到来，時間就這様日復一日地過去。"
        },
        {
            "id": 17,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢",
            "content": "以、以后我就算害怕，也不会出声了。"
        },
        {
            "id": 18,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢",
            "content": "宁喜歓的東西我都会好好記住。"
        },
        {
            "id": 19,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢",
            "content": "剣術……我也会尽快学会的。"
        },
        {
            "id": 20,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢",
            "content": "就算疼也不会逃走了。"
        },
        {
            "id": 21,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢",
            "content": "所以……求求袮們放我出去叭……"
        },
        {
            "id": 22,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢",
            "content": "爸爸……媽媽……"
        },
        {
            "id": 23,
            "content": "就這様，当我開始対一切黑暗都変得麻木時。"
        },
        {
            "id": 24,
            "content": "那扇无論我如何敲打、抓撓都紋絲不動的門，却輕而易舉地打開了，輕易到譲我過去所有的爭扎都顕得空虚又可笑。"
        },
        {
            "id": 25,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢",
            "content": "爸、爸爸……我……以后一定……"
        },
        {
            "id": 26,
            "content": "我没抱任何期待。"
        },
        {
            "id": 27,
            "content": "温柔的話語、担憂的目光之類的東西，対我来説就像从走廊這頭到那頭一様遥遠。"
        },
        {
            "id": 28,
            "content": "我只不過是，想知道理由而已。"
        },
        {
            "id": 29,
            "content": "我想知道他們為什么要堵住保険箱、我做錯了什么、我今后到底該怎么做。"
        },
        {
            "id": 30,
            "content": "但是……似乎連這些問題都越界了。"
        },
        {
            "id": 31,
            "teller": "？？？",
            "title": "蜘蛛巢的父輩",
            "content": "看来没有産生糾纏啊。"
        },
        {
            "id": 32,
            "teller": "？？？",
            "title": "蜘蛛巢的父輩",
            "content": "兩天后再試一次叭。"
        },
        {
            "id": 33,
            "content": "只棄下了一句干巴巴的感想，父輩們就回到了各自的走廊。"
        },
        {
            "id": 34,
            "content": "无端延續的暴力枷鎖。"
        },
        {
            "id": 35,
            "content": "意圖将我嵌入自己喜好的任性之舉。"
        },
        {
            "id": 36,
            "content": "愉悦地拍着手旁観的冷漠視綫。"
        },
        {
            "id": 37,
            "content": "被当作素材対待的強烈痛楚。"
        },
        {
            "id": 38,
            "content": "這四根絲綫化作了勒緊我咽喉的縄索。"
        },
        {
            "id": 39,
            "content": "互相从不同的方向不断拉祉着我，真是一条……"
        },
        {
            "id": 40,
            "content": "可恨的縄索。"
        },
        {
            "id": 41,
            "content": "所以，没有我，他們也没法活下去。"
        },
        {
            "id": 42,
            "content": "他們已然被抛弃，也再无其他絲綫可以依附。"
        },
        {
            "id": 43,
            "content": "所以我将去斬断他們僅存的那一根絲綫。"
        },
        {
            "id": 44,
            "content": "而若要将我斬切，必須先斬断他物。"
        },
        {
            "id": 45,
            "content": "没有目的，只是揮動刀刃，将目所能及之物尽数斬断。"
        },
        {
            "id": 46,
            "content": "那因未曾親眼所見而无望去描絵地獄之景的愚鈍父輩。"
        },
        {
            "id": 47,
            "content": "那人連自己的筆尖已然僵硬凝固都未曾察覚，却仍強烈地渴求着干涸的霊感，和早已死去的創意。"
        },
        {
            "id": 48,
            "content": "每次我睜開双眼，總是踏足于死亡的辺縁，佇立于彼岸之上。"
        },
        {
            "id": 49,
            "content": "父輩細心地剖去我身上的廃料残渣，在画紙之上反復絵涂地獄的惨状之時，我的喉隆都嘶唖欲裂，心跳快到几乎要撕開胸堂。"
        },
        {
            "id": 50,
            "content": "為了呈現悲惨絶景而布下的演出。"
        },
        {
            "id": 51,
            "content": "那是足以譲我覚得生命会就此終結般的劇烈痛楚，但父輩却対我身体的極限了如指掌。"
        },
        {
            "id": 52,
            "content": "它処在不至于譲我死去、或是失去意識的界限内，却将我、将我這塊素材雕琢得足以発出最極致痛苦的悲鳴。"
        },
        {
            "id": 53,
            "content": "所以。"
        },
        {
            "id": 54,
            "content": "所以，每当身体上的淤青隠隠作痛時，我便会試着去回想那些被千刀万刳的記憶。"
        },
        {
            "id": 55,
            "content": "這是何時的痛楚捏。是現在的。還是很久以前的。或是尚未到来的某一天的捏。“現在”這个詞實在太過短暫，以至于説出口的瞬間，它就已經流逝，化為了過去。"
        },
        {
            "id": 56,
            "content": "即便如此，那些疼痛、傷口、傷痕也不会消逝。它們在肉眼可見之処，有時在不可見之処停留。因為痛楚總是或遅或早地到来，我将永遠无法知暁此時此刻的痛楚為何物，并一直這様活下去。"
        },
        {
            "id": 57,
            "content": "像不惜棄掉性命，也眷恋着花朶的蝴蝶一様。"
        },
        {
            "id": 58,
            "content": "像无論被如何拍打，都不愿离去的蝴蝶一様。"
        },
        {
            "id": 59,
            "content": "蝴蝶并非不肯离開，也并非忘記了如何离開，只是它从一開始就没有学会過叭。剛破繭而出的蝴蝶被蛛絲所束縛，那双只会撲騰的翅膀，不過是徒有其名罷了。"
        },
        {
            "id": 60,
            "content": "這只蝴蝶，我，既不知如何做我自己，也不知如何飛翔，亦无法离去，只能停留在此処。"
        },
        {
            "id": 61,
            "content": "這个事實父輩比任何人都更清楚。能劬不帯絲毫遅疑地対我施以暴力，想必就是因為這个叭。"
        },
        {
            "id": 62,
            "content": "即使想怎么打就怎么打我，劬得到什么就朝我抛什么。"
        },
        {
            "id": 63,
            "content": "即使対我惡言相向，父輩也知道我絶无可能逃离。"
        },
        {
            "id": 64,
            "content": "只是，尽管每天都要一直挨打到父輩的怒火平息為止，我也仍不知道那怒火究竟从何而来，也不知道為何我必須承受那一切暴力。"
        },
        {
            "id": 65,
            "content": "那毫无縁由的憤怒，如同傷痕般伴随着痛苦不断銘刻在我身上。"
        },
        {
            "id": 66,
            "content": "伴随着痛苦不断銘刻，我領悟了一些東西。"
        },
        {
            "id": 67,
            "content": "在彼岸生存，无異于在漆黑的長夜中僅凭一盞灯火求生。"
        },
        {
            "id": 68,
            "content": "我可以去往任何時間，但无論在那个時間里，我都无法从這条走廊中脱身，所以我努力去尋找生存的理由、牽挂、枷鎖，尋找我的那盞灯火。"
        },
        {
            "id": 69,
            "content": "有時是从以外聘講師的名義来訪的人身上，有時是从掉落在地面上的東西里。"
        },
        {
            "id": 70,
            "content": "但那些東西，最終都因為違背了某人心意這種理由离我遠去、支离破碎。那些怜憫我的、以及我怜憫的存在，也全都会因為父輩的一次心血来潮而被悉数毀坏。"
        },
        {
            "id": 71,
            "content": "它們在那野蛮的歓愉中被削去，不、是被千刀万刳，也不対、是被斬切、是被斬断……即便如此，也无法徹底割舍。留下一種令人不安而不快的余感。"
        },
        {
            "id": 72,
            "content": "連些微的不快都无法忍受，只要不合心意就必須立刻毀掉才肯罷休的，幼稚而卑劣的心性。父輩只是存活于世，就譲環繞着我的所有絲綫都糾纏錯乱。"
        },
        {
            "id": 73,
            "content": "每当那時，我總会在父輩离去后的空蕩房間里，任由泪水奪眶而出，可尽管如此……"
        },
        {
            "id": 74,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢之刃",
            "content": "……"
        },
        {
            "id": 75,
            "content": "是因為明天的我已經把所有的悲傷先行奪走、消耗殆尽了麼。"
        },
        {
            "id": 76,
            "content": "唯独這一天，眼泪如同干涸的泉水般，一滴也没有流下。"
        },
        {
            "id": 77,
            "content": "耳辺回蕩着，生鏽了的沈重枷鎖的声音。"
        },
        {
            "id": 78,
            "content": "它并非从脚踝下方傳来。"
        },
        {
            "id": 79,
            "content": "而是从記憶的最深処，悉悉窣窣地傳来。"
        },
        {
            "id": 80,
            "content": "将我層層纏繞的事物中充満了虚偽。那些倣佛為了掩盖恐惧，被痛苦浸泡、又以痛苦層層涂満的東西，交織于我的人生之上，交錯糾纏成无法解開的復雑死結。緊實細密得令人窒息。"
        },
        {
            "id": 81,
            "content": "我要出去。我想出去。"
        },
        {
            "id": 82,
            "content": "僅凭切實的期盼是打不開那扇門的。"
        },
        {
            "id": 83,
            "content": "没有一絲縫隙的黑暗。膨脹雍腫的死寂。這个小小的保険箱，長大的我已經无法入内。就算出去了，那个逼仄的房間里也没有我的容身之所。即便如此，我依旧活在那逼仄的房間里，活在蜘蛛巢中，走進了這个狭小而黑暗的保険箱。"
        },
        {
            "id": 84,
            "content": "我的小小世界，我那狭窄的房間，永遠无法逃离的鳥籠。或許是个令人懐念的地方，一个并不歓迎我的地方。我為什么会想要出去捏。明明那扇門依旧打不開。"
        },
        {
            "id": 85,
            "content": "就算出去了，又有誰会歓迎我捏？"
        },
        {
            "id": 86,
            "content": "像是為了遮掩緊随那疑問而来的恐惧，被痛苦浸泡、又以痛苦層層涂満的残像，交織于我的人生之上，交錯糾纏成无法解開的復雑死結，向我涌来。"
        },
        {
            "id": 87,
            "content": "緊實細密得令人窒息。層層纏繞的残像、人生、我。"
        },
        {
            "id": 88,
            "content": "我从我自身誕生，无可奈何地成長起来。"
        },
        {
            "id": 89,
            "content": "<i>袮陷入了時間糾纏啊，<ruby=Yoshihide>良秀</ruby>。</i>"
        },
        {
            "id": 90,
            "content": "終于，一縷微弱的光透了進来。"
        },
        {
            "id": 91,
            "content": "我将要迎来的起始与終結，那些只会帯来痛苦的絲綫，如同針一般刺入我的眼中。"
        },
        {
            "id": 92,
            "content": "僅凭遺忘是无法失去的。有些東西只有失去了才能遺忘。"
        },
        {
            "id": 93,
            "content": "我必須斬断纏繞着我的所有絲綫。"
        },
        {
            "id": 94,
            "content": "我必須斬殺那些父輩。"
        },
        {
            "id": 95,
            "content": "譲一切都无法浮起，譲任何人都无法仰望天空，譲任何事物都无法再呼喚我。"
        },
        {
            "id": 96,
            "model": "료슈",
            "teller": "<size=50%><voffset=0.3em>Yoshihide</voffset></size>\n良秀",
            "title": "蜘蛛巢之刃",
            "content": "……"
        },
        {
            "id": 97,
            "content": "脳袋輕飄飄的。"
        },
        {
            "id": 98,
            "content": "也許是因為无数次揮動了刀、揮動了阿頼耶識，曾占据了漫長時光的可怖記憶，怎么也浮現不出来了。"
        },
        {
            "id": 99,
            "content": "那些纏繞在我身上的沈重絲綫，倣佛被从我身上剖去般。"
        },
        {
            "id": 100,
            "content": "連吸气呼气、握拳又張開這種微小的動作都譲我感到暢快。"
        },
        {
            "id": 101,
            "content": "<ruby=Yoshihide>良秀</ruby>。<ruby=Yoshihide>良秀</ruby>。<ruby=Yoshihide>良秀</ruby>。"
        },
        {
            "id": 102,
            "content": "父輩們不停地呼喚着我的名字。究竟是失去了什么，才会譲這些在我痛苦爭扎時都一言不発的父輩們如此凄惨捏？"
        },
        {
            "id": 103,
            "content": "明明那是曾数万次刺入鼓膜的声音，如今它的回響却只譲人感到不快。"
        },
        {
            "id": 104,
            "content": "所以，我静候着那分痛苦迎来終結。"
        },
        {
            "id": 105,
            "content": "不，這个説法顕然存在矛盾。即便痛苦終結，我又能做些什么捏？"
        },
        {
            "id": 106,
            "content": "已然終結的痛苦，不過是个連家具都没有的、空无一物的房間。就像父輩曾經為我読的絵本般，結局之后什么也不会留下。如今面対結局，我又能改変什么捏。"
        },
        {
            "id": 107,
            "content": "未能找到那个答案的我，被困于痛苦之中狼狽不堪。抓撓牆壁，強忍哭声，有時面无表情地佇立着，不知所措，惶恐不安。"
        },
        {
            "id": 108,
            "content": "某一天，父輩給我読的絵本里。"
        },
        {
            "id": 109,
            "content": "一个人造出翅膀、振翅高飛，直面天空中耀眼的光芒，然而故事并未就此結束。它真正的結局，是他的翅膀被火焰呑噬、整个人墜入翻涌的海浪之中，被徹底呑没。而父輩的故事在抵達那令人不快的可怕悲劇前都未曾停止。"
        },
        {
            "id": 110,
            "content": "即使他為了譲我忘記那分憂郁逓来令一本絵本，也依然没有任何改変。"
        },
        {
            "id": 111,
