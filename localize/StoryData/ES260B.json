{
    "dataList": [
        {
            "id": 0,
            "place": "大観园 演武場",
            "model": "뿅망히스",
            "content": "我要給袮們一个関于先発制人的新課題。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 1,
            "model": "뿅망히스",
            "content": "不管襲撃過来的家夥的数量有多少，或看起来有多危険，从退縮的那一瞬間開始就已經輸了，明白了麼。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 2,
            "model": "뿅망히스",
            "content": "看看我。我有没有因為害怕対方而挟起尾巴逃砲過？",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 3,
            "model": "싱클레어",
            "content": "那種情况……好像確實没有過……",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 4,
            "model": "뿅망히스",
            "content": "譲那些書呆子們浪費時間思考策略去叭。听着，世界上没有什么問題是袮不能通過气勢来解决的。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 5,
            "content": "能譲以實瑪利和奥提斯痛心疾首的話語，被希斯克利夫毫无負担地脱口而出。"
        },
        {
            "id": 6,
            "model": "뿅망히스",
            "content": "在我看来，袮們都缺点魄力。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 7,
            "model": "뿅망히스",
            "content": "所以，袮們面対会場里面那些装腔作勢、不値一提的家夥們才会什么話也説不出来，只能手足无措，不是麼？",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 8,
            "model": "가시춘",
            "title": "鴻园的家主",
            "content": "……",
            "teller": "賈惜春"
        },
        {
            "id": 9,
            "content": "可能是被戳到了痛処，賈惜春并没有反駁。"
        },
        {
            "id": 10,
            "model": "뿅망히스",
            "content": "譲我教袮們最可靠的鍛錬魄力的方法。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 11,
            "model": "뿅망히스",
            "content": "試試跟我頂嘴。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 12,
            "model": "뿅망히스",
            "content": "不用害怕，堂堂正正地！",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 13,
            "model": "싱클레어",
            "content": "就算這么説，怎么能……",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 14,
            "model": "뿅망히스",
            "content": "順帯一提，无論袮們説什么，我都能照単全收。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 15,
            "model": "뿅망히스",
            "content": "与袮們兩个不同，多虧了在后巷摸爬滾打的数十年，我已經練就了足劬的魄力来應対各種侮辱。我可是无敵的。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 16,
            "model": "싱클레어",
            "content": "炒……炒死了……希斯克利夫先生……！",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 17,
            "model": "뿅망히스",
            "content": "対，就是這様。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 18,
            "model": "싱클레어",
            "content": "像袮這様的算什么老師！就只会在那里擺架子……",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 19,
            "model": "가시춘",
            "title": "鴻园的家主",
            "content": "哦……這句可有点扎心了？",
            "teller": "賈惜春"
        },
        {
            "id": 20,
            "model": "뿅망히스",
            "content": "……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 21,
            "model": "뿅망히스",
            "content": "袮這混蛋……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 22,
            "model": "뿅망히스",
            "content": "要是放在以前，我大概会這么説着，抄起這把錘子……不，應該是我的球棒，会在我説完之前就先一步飛出去叭。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 23,
            "model": "뿅망히스",
            "content": "但現在我也改変了。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 24,
            "model": "뿅망히스",
            "content": "而且袮也一様。袮的眼神比以前更有活力了。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 25,
            "model": "뿅망히스",
            "content": "記住袮現在跟我頂嘴時的眼神。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 26,
            "model": "싱클레어",
            "content": "好的……！",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 27,
            "model": "뿅망히스",
            "content": "那么，現在開始實戦叭。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 28,
            "model": "뿅망히스",
            "content": "最合适的対手就在袮們的身辺。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 29,
            "model": "뿅망히스",
            "content": "袮們兩个，拿起武器。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 30,
            "model": "싱클레어",
            "content": "什么？我和賈惜春小姐麼？",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 31,
            "model": "뿅망히스",
            "content": "我這分魄力，就是当年在后巷時每天跟哥們儿抄拳頭練出来的。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 32,
            "model": "뿅망히스",
            "content": "有誰折了我的骼膊，我就打断対方的腿作為回敬。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 33,
            "model": "가시춘",
            "title": "鴻园的家主",
            "content": "這……真的算拍档麼？",
            "teller": "賈惜春"
        },
        {
            "id": 34,
            "content": "賈惜春困惑地問道。"
        },
        {
            "id": 35,
            "model": "싱클레어",
            "content": "額……那就……請多指教了。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 36,
            "model": "가시춘",
            "title": "鴻园的家主",
            "content": "唔……不用手下留情叭？",
            "teller": "賈惜春"
        },
        {
            "id": 37,
            "model": "싱클레어",
            "content": "……不用。",
            "teller": "辛克莱",
            "title": "11号罪人"
        }
    ]
