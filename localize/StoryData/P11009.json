{
    "dataList": [
        {
            "id": 0,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "明明宁偶尓也可以品嘗一下別的茶的。我泡的双和茶真的有那么可口麼……？"
        },
        {
            "id": 1,
            "content": "師父像是我問了理所当然的事情那般調侃我，不禁譲我很難為情。前輩就要完成委托帰来了，所以我全開了窗戸。"
        },
        {
            "id": 2,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "前輩説他只会在工坊稍作停留，我想他很快就会回来了。"
        },
        {
            "id": 3,
            "content": "没有委托的日子里總是如此風平浪静。"
        },
        {
            "id": 4,
            "content": "与師父同飲双和茶聊些日常的話題，或是与将要帰来的前輩担心以后的租金，過着平凡又温暖的一天。"
        },
        {
            "id": 5,
            "content": "那是段与我們“黎明”的名称并不相符，柔和且温暖的時光。"
        },
        {
            "id": 6,
            "content": "我很享受這段時光。"
        },
        {
            "id": 7,
            "content": "我作為收尾人取得的成績并不差。"
        },
        {
            "id": 8,
            "content": "在師父的悉心指導下，我毫不費力地掌握了如何使用烙印工坊的武器，以及作為一名收尾人所需的各種知識。"
        },
        {
            "id": 9,
            "content": "无論接到怎様的委托，因為優秀的師父与前輩技藝高超，也都可以迎刃而解，随着成績自然而然地積累起来，我收尾人的等級也在不断上升。"
        },
        {
            "id": 10,
            "content": "那是……我在不断成為一个更好的人的証明。"
        },
        {
            "id": 11,
            "content": "但是。"
        },
        {
            "id": 12,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "在這分委托中我也没出多少力啊……"
        },
        {
            "id": 13,
            "content": "我的師父在烟霾戦争時是一位名声顕赫的收尾人，我的前輩則単槍匹馬就能解决都市傳説級的委托。"
        },
        {
            "id": 14,
            "content": "在黎明事務所的少数成員中，我的不懈努力，頂多算是為了不落人后而摸索着跟上他們的步伐而已。"
        },
        {
            "id": 15,
            "content": "他們總是鼓励我説我也能帮上很大的忙……但這種隔离感還是譲我感到无比空洞。"
        },
        {
            "id": 16,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "傳聞中的邀請函……是被評定為都市惡疾級的圖書館麼……？"
        },
        {
            "id": 17,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "我也跟着去麼？"
        },
        {
            "id": 18,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "我能劬……帮到那兩个人麼……？"
        },
        {
            "id": 19,
            "content": "我的自我懐疑只会不断地増長。"
        },
        {
            "id": 20,
            "content": "同時，我対他們的信頼也在不断地膨脹。"
        },
        {
            "id": 21,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "這次的委托我也只要做好輔助就好……"
        },
        {
            "id": 22,
            "content": "即使我不出什么力，他們二人也能輕松解决委托……我如此信頼着他們。"
        },
        {
            "id": 23,
            "content": "懐有着這種膚浅且自私的信頼，并心安理得。"
        },
        {
            "id": 24,
            "content": "我……踏入了圖書館。"
        },
        {
            "id": 25,
            "content": "无論是到最后都在担心着我的師父。"
        },
        {
            "id": 26,
            "content": "還是直到最后都還譲我不必担心、没有責怪我的前輩。"
        },
        {
            "id": 27,
            "content": "就連向我伸出援手的事務所的收尾人們。"
        },
        {
            "id": 28,
            "content": "他們都没能戦勝圖書館，化作了書籍。"
        },
        {
            "id": 29,
            "content": "一直伴我左右的人們消失得无影无踪，只剩我一人独活。"
        },
        {
            "id": 30,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "哈……哈啊……"
        },
        {
            "id": 31,
            "content": "我思考着重返戦場上又有什么意義。"
        },
        {
            "id": 32,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "掩飾真心也没那么糟羔麼……怎么可能捏。"
        },
        {
            "id": 33,
            "content": "我想過是不是應該逃出去向協会报告此事，并再次請求援助。"
        },
        {
            "id": 34,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "没、没錯。没人能理解我的真心。"
        },
        {
            "id": 35,
            "content": "恐惧感包裹着我，譲我一点点后退，无法向前邁出那怕一步。"
        },
        {
            "id": 36,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "走上這条路……真的只会給我帯来痛苦麼？"
        },
        {
            "id": 37,
            "content": "我每退一步，耳辺就会響起一陣美妙而平静的低語。"
        },
        {
            "id": 38,
            "content": "忽然。"
        },
        {
            "id": 39,
            "content": "我開始懐疑，懐疑自己至今為止的所作所為，是否都只是自我保護的借口而已。"
        },
        {
            "id": 40,
            "content": "我慢慢意識到，如果再継續以他人為保護和美化自己的盾牌，我就永遠无法邁向前方。"
        },
        {
            "id": 41,
            "content": "正確的道路應当是堅定地邁向前方，并非總是以為了他人為借口而屡次退縮。"
        },
        {
            "id": 42,
            "content": "我甚至从一開始就偏离了正確的道路。"
        },
        {
            "id": 43,
            "content": "我分明是一个骯臓的、丑陋的人。"
        },
        {
            "id": 44,
            "content": "我承認，自己与都市中那些自私自利的人并没有什么不同……"
        },
        {
            "id": 45,
            "content": "我停下了后退的脚步。"
        },
        {
            "id": 46,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "无視了他人……就能劬更愛自己麼？"
        },
        {
            "id": 47,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "我不知道。我甚至不能確定。"
        },
        {
            "id": 48,
            "content": "我遮住眼睛以隠去不安……"
        },
        {
            "id": 49,
            "content": "撫住耳朶以隔絶那美妙之声……"
        },
        {
            "id": 50,
            "content": "堵住嘴巴以不再言語那些為了他人的偽善。"
        },
        {
            "id": 51,
            "content": "我相信不加修飾的現實，并不比我那自私的想象中的更加冷酷无情。"
        },
        {
            "id": 52,
            "content": "我向自己曾逃离了的戦場走去。"
        },
        {
            "id": 53,
            "content": "真是遺憾……"
        },
        {
            "id": 54,
            "content": "這孩子并没能展現出真實的自我，在過程中半途而廃地節制了。"
        },
        {
            "id": 55,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "……没人能替悲傷的我哭泣。"
        },
        {
            "id": 56,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "最終，這分痛苦只能由我承担。"
        },
        {
            "id": 57,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "因為這是我如不可磨滅的烙印般的責任。"
        },
        {
            "id": 58,
            "content": "如果這孩子能更加重視自己的感受就好了。"
        },
        {
            "id": 59,
            "content": "這孩子直面自己那起伏不定如業火般的情感，将其鍛造成了工具。"
        },
        {
            "id": 60,
            "content": "最終没能触及純粹的自我，将剣指向了敵人。"
        },
        {
            "id": 61,
            "content": "但没関系。"
        },
        {
            "id": 62,
            "content": "我認識一位跟他很像的孩子，那孩子在瞬間就触触到了極致的自我。"
        },
        {
            "id": 63,
            "content": "那孩子一開始也并没有听取我的話……但后来，他還是選擇了側耳傾听。"
        },
        {
            "id": 64,
            "content": "他們二人是如此相像，結局想必也会很像叭。"
        },
        {
            "id": 65,
            "content": "這孩子注定会停下脚步，他会再一次退縮。"
        },
        {
            "id": 66,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "袮錯了，峠門小姐。"
        },
        {
            "id": 67,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "我很害怕，怕得不得了，我甚至想要立刻抛下這把剣逃离，但是……"
        },
        {
            "id": 68,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "我不想止步于此。"
        },
        {
            "id": 69,
            "content": "即使我認為不要去走那条充満痛苦的路比較好。"
        },
        {
            "id": 70,
            "content": "从外殻中重獲新生的孩子，舞動着単翼勉強着自己試圖飛向更高更遠的天空。"
        },
        {
            "id": 71,
            "content": "他不知道的是，在以情感為燃料呑噬着他的火焰中，他那不穏定的理智只能劬勉強維持他翅膀的形態。"
        },
        {
            "id": 72,
            "content": "面対着做好接待准備的圖書館的孩子們，他堅定而威風地向他們舉起了剣。"
        },
        {
            "id": 73,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "這分情感，定是賜予我的命運。"
        },
        {
            "id": 74,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "……我要振翅高飛。"
        },
        {
            "id": 75,
            "model": "싱클레어",
            "teller": "辛克莱",
            "title": "黎明事務所",
            "content": "打破這阻碍我的外殻，飛往更高処。"
        },
        {
            "id": 76,
            "content": "在泛濫的情感中，這虚幻脆弱的翅膀還能堅持多久不会被融化捏。"
        },
        {
            "id": 77,
            "content": "雖然現在還无从得知，但等到袮因翅膀融化而墜落的那一天……"
        },
        {
            "id": 78,
            "content": "到那時再听听我説的話叭，親愛的孩子。"
        }
    ]
}