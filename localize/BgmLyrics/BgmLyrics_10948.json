    "dataList": [
        {
            "id": 0,
            "content": "<style=\"DEN_CP9_1\">阿頼耶没有在等待任何人。"
        },
        {
            "id": 1,
            "content": "<style=\"DEN_CP9_1\">若記憶消散，時間也会消失。"
        },
        {
            "id": 2,
            "content": "<style=\"DEN_CP9_1\">袮回来的日子会是今天，還是明天捏。不，袮還会回来麼？"
        },
        {
            "id": 3,
            "content": "<style=\"DEN_CP9_1\">堅信着那一定会回来的約定，我昼夜不忘地等待着。"
        },
        {
            "id": 4,
            "content": "<style=\"DEN_CP9_1\">即便斬去、再度斬去，那一日的怨恨也无法斬断，只会卷土重来。"
        },
        {
            "id": 5,
            "content": "<style=\"DEN_CP9_1\">……不。現在……我還不想回去。"
        },
        {
            "id": 6,
            "content": "<style=\"DEN_CP9_1\">這里好黑……好安静……"
        }
    ]
}