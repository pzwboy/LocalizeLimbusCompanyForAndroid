{
    "dataList": [
        {
            "id": 0,
            "content": "在我年少迷茫之時"
        },
        {
            "id": 1,
            "content": "袮悄然出現，為這扇心門開鎖"
        },
        {
            "id": 2,
            "content": "如絲綫一般，花瓣舒展"
        },
        {
            "id": 3,
            "content": "一朶鮮紅的河原撫子花"
        },
        {
            "id": 4,
            "content": "袮使我発現，原来我還存有能力関愛他人"
        },
        {
            "id": 5,
            "content": "原来在我的内心深処還留有一分純真"
        },
        {
            "id": 6,
            "content": "因為此刻我明白"
        },
        {
            "id": 7,
            "content": "疼痛无从定義過去"
        },
        {
            "id": 8,
            "content": "我們生来就被賜予能劬跨越无数波折的力量"
        },
        {
            "id": 9,
            "content": "其實没有那么苦"
        },
        {
            "id": 10,
            "content": "因為有袮和我相伴"
        },
        {
            "id": 11,
            "content": "在我們的有生之年，珍惜這一切"
        },
        {
            "id": 12,
            "content": "因為“再”并不是“再見”的“再”"
        },
        {
            "id": 13,
            "content": "譲我們重播回憶"
        },
        {
            "id": 14,
            "content": "我確信我必須挺身努力"
        },
        {
            "id": 15,
            "content": "袮値得擁有整个世界，甚至更多"
        },
        {
            "id": 16,
            "content": "但其實袮更希望"
        },
        {
            "id": 17,
            "content": "希望我們可以一同度過這有限的時光"
        },
        {
            "id": 18,
            "content": "僅靠保護遠遠不劬"
        },
        {
            "id": 19,
            "content": "就算付出，也无法填満袮那渴求愛的空杯"
        },
        {
            "id": 20,
            "content": "我反復自問——"
        },
        {
            "id": 21,
            "content": "我憧什么是愛？"
        },
        {
            "id": 22,
            "content": "明明从未体驗過，又怎能把它重現？"
        },
        {
            "id": 23,
            "content": "我只知道，一定要譲袮茁壮成長"
        },
        {
            "id": 24,
            "content": "若袮缺乏養分"
        },
        {
            "id": 25,
            "content": "我愿把血液中的每一滴都澆灌給袮"
        },
        {
            "id": 26,
            "content": "如今我終于明白"
        },
        {
            "id": 27,
            "content": "犠牲之路才是捷径"
        },
        {
            "id": 28,
            "content": "我的欠缺将无法顛覆這个事實："
        },
        {
            "id": 29,
            "content": "我其實只愿能給袮提供最好的一生"
        },
        {
            "id": 30,
            "content": "這条紅綫将永不会被斬断"
        },
        {
            "id": 31,
            "content": "“再”更不是“再見”的“再”"
        },
        {
            "id": 32,
            "content": "袮愿意最終原諒我麼？"
        }
    ]
}