        {
            "id": 0,
            "content": "<style=\"djp_CP6_2\">我多么希望能劬擁有",
            "vocalid": 0
        },
        {
            "id": 1,
            "content": "<style=\"djp_CP6_2\">一个更加幸福明亮的未来",
            "vocalid": 0
        },
        {
            "id": 2,
            "content": "<style=\"djp_CP6_2\">我站立于大門之前",
            "vocalid": 0
        },
        {
            "id": 3,
            "content": "<style=\"djp_CP6_2\">親愛的過去",
            "vocalid": 0
        },
        {
            "id": 4,
            "content": "<style=\"djp_CP6_2\">我已下决心",
            "vocalid": 0
        },
        {
            "id": 5,
            "content": "<style=\"djp_CP6_2\">袮忍耐了多少分我的憤怒",
            "vocalid": 0
        },
        {
            "id": 6,
            "content": "<style=\"djp_CP6_2\">我那野蛮又可耻的態度",
            "vocalid": 0
        },
        {
            "id": 7,
            "content": "袮忽視了多少次袮的美好",
            "vocalid": 1
        },
        {
            "id": 8,
            "content": "袮那直率又真誠的作為",
            "vocalid": 1
        },
        {
            "id": 9,
            "content": "<style=\"djp_CP6_2\">在這命運之地",
            "vocalid": 0
        },
        {
            "id": 10,
            "content": "<style=\"djp_CP6_2\">我会譲這一切結束",
            "vocalid": 0
        },
        {
            "id": 11,
            "content": "袮愿意看我結束麼？",
            "vocalid": 1
        },
        {
            "id": 12,
            "content": "<style=\"djp_CP6_2\">奥",
            "vocalid": 0
        },
        {
            "id": 13,
            "content": "<style=\"djp_CP6_2\">我們在原地旋轉",
            "vocalid": 0
        },
        {
            "id": 14,
            "content": "<style=\"djp_CP6_2\">手中緊握",
            "vocalid": 0
        },
        {
            "id": 15,
            "content": "<style=\"djp_CP6_2\">由自我而生的痛苦",
            "vocalid": 0
        },
        {
            "id": 16,
            "content": "<style=\"djp_CP6_2\">未能傳達的情感",
            "vocalid": 0
        },
        {
            "id": 17,
            "content": "<style=\"djp_CP6_2\">紡織一条条袮永遠无法理解的",
            "vocalid": 0
        },
        {
            "id": 18,
            "content": "<style=\"djp_CP6_2\">我們各自独創的暦史",
            "vocalid": 0
        },
        {
            "id": 19,
            "content": "<style=\"djp_CP6_2\">因為我知道",
            "vocalid": 0
        },
        {
            "id": 20,
            "content": "<style=\"djp_CP6_2\">一定是因為我",
            "vocalid": 0
        },
        {
            "id": 21,
            "content": "<style=\"djp_CP6_2\">袮放弃了笑顔",
            "vocalid": 0
        },
        {
            "id": 22,
            "content": "<style=\"djp_CP6_2\">袮眼中的希望就此被奪去",
            "vocalid": 0
        },
        {
            "id": 23,
            "content": "<style=\"djp_CP6_2\">一定是因為我",
            "vocalid": 0
        },
        {
            "id": 24,
            "content": "<style=\"djp_CP6_2\">袮不得不対我説出這些幌言",
