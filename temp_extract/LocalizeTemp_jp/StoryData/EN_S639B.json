{
    "dataList": [
        {
            "id": 0,
            "place": "呼嘯山庄 實驗室",
            "content": "希斯克利夫満身傷痕，似乎連拿穏武器的力气都没有了。"
        },
        {
            "id": 1,
            "model": "히스클리프",
            "content": "媽的……媽的！",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 2,
            "content": "随着最后一絲力气也消失殆尽，他手里的球棒掉在了地上。"
        },
        {
            "id": 3,
            "model": "히스클리프",
            "content": "当我自愿离開這座宅邸的時候……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 4,
            "model": "히스클리프",
            "content": "我対自己発誓要做出改変再回来。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 5,
            "model": "히스클리프",
            "content": "我想這様至少当我站在凱瑟琳面前時，他就不会再為我感到難堪……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 6,
            "model": "히스클리프",
            "content": "但……袮看看我。到頭来我還是保護不了凱瑟琳，連接近他都難如登天。我像个笨子一様，甚至連武器都握不穏。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 7,
            "model": "단테",
            "content": "<希斯克利夫……>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 8,
            "model": "히스클리프",
            "content": "我憧。我的人生里……没有一絲値得夸耀的東西。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 9,
            "model": "히스클리프",
            "content": "我没受過教育，性格也不好，還經常罵人。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 10,
            "model": "히스클리프",
            "content": "告訴我叭，鐘表頭……不。經理。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 11,
            "model": "히스클리프",
            "content": "我要面対的罪孼，是如此絶望而又无尽来襲的麼？",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 12,
            "model": "히스클리프",
            "content": "无論我将其揮開多少次，這无尽的罪孼還是会向我襲来，我的人生難道就錯到如此地步了麼？",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 13,
            "content": "不会是那様的。"
        },
        {
            "id": 14,
            "content": "我想要相信。"
        },
        {
            "id": 15,
            "content": "如果是擁有想要継續向前邁進的意志和决心的人的話……"
        },
        {
            "id": 16,
            "content": "就終有一天可以抜云見日。"
        },
        {
            "id": 17,
            "content": "迄今為止在旅途中的努力与領悟絶対没有白費。"
        },
        {
            "id": 18,
            "content": "所以，也請相信我所為袮指明的道路。"
        },
        {
            "id": 19,
            "content": "但是……"
        },
        {
            "id": 20,
            "model": "뫼르소",
            "content": "他們……又涌過来了。",
            "teller": "默尓索",
            "title": "5号罪人"
        },
        {
            "id": 21,
            "model": "뫼르소",
            "content": "数量多于先前。",
            "teller": "默尓索",
            "title": "5号罪人"
        },
        {
            "id": 22,
            "content": "但如果我向袮展示的路是如此黑暗，看不到一絲光明時……"
        },
        {
            "id": 23,
            "model": "단테",
            "content": "<我該……>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 24,
            "content": "当我似乎也迷失了方向時……該如何是好……"
        }
