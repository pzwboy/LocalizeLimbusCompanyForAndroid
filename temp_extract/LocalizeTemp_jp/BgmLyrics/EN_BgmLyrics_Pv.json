{
    "dataList": [
        {
            "id": "0",
            "content": "……嘖。"
        },
        {
            "id": "1",
            "content": "出発咯，布隆布隆。"
        },
        {
            "id": "2",
            "content": "向地獄出発叭。"
        },
        {
            "id": "3",
            "content": "我走下一条路径"
        },
        {
            "id": "4",
            "content": "帯我回到過去"
        },
        {
            "id": "5",
            "content": "剥開樹木之手，盗走一顆"
        },
        {
            "id": "6",
            "content": "那是后悔者的好友——禁断之果"
        },
        {
            "id": "7",
            "content": "我咬下它的果皮\n咀嚼它水嫩的果肉"
        },
        {
            "id": "8",
            "content": "咽下它温暖的膿水"
        },
        {
            "id": "9",
            "content": "袮成為了袮最厭惡的【我】"
        },
        {
            "id": "10",
            "content": "我們呑噬時間\n倒帯"
        },
        {
            "id": "11",
            "content": "喇們\n如果袮想譲我持續存活"
        },
        {
            "id": "12",
            "content": "如果袮想譲我寛恕原諒"
        },
        {
            "id": "13",
            "content": "如果袮想譲我們假装扮演文明社会的住人"
        },
        {
            "id": "14",
            "content": "当我們死于一次又一次輪回\n（当我們死于一次又一次輪回）"
        },
        {
            "id": "15",
            "content": "我心中的正義，\n那个為我狡辯的自我使我的罪惡合理化"
        },
        {
            "id": "16",
            "content": "喇們\n為什么唯有死才能終結我受到的拷打？"
        },
        {
            "id": "17",
            "content": "為什么誰也无法理解我的悲苦？"
        },
        {
            "id": "18",
            "content": "為什么戴冠的王者終帰是最暴力凶残的那一个？"
        },
        {
            "id": "19",
            "content": "這是錬獄\n（錬獄）"
        },
        {
            "id": "20",
            "content": "我們為各自建起的錬獄"
        },
        {
            "id": "21",
            "content": "我們相互復蘇，存于地獄之中"
        }
    ]
}