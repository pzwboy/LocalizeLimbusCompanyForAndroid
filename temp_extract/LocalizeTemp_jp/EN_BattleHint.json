{
    "dataList": [
        {
            "id": "1",
            "content": "領取鏡像迷宮的奨励時需要消耗脳啡汰模塊。"
        },
        {
            "id": "2",
            "content": "每个技能都至少包含1枚硬幣。"
        },
        {
            "id": "3",
            "content": "硬幣的威力会随着其朝向而発生改変。"
        },
        {
            "id": "4",
            "content": "硬幣的朝向也会影響技能效果的発動。"
        },
        {
            "id": "5",
            "content": "理智値低于特定閾値的単位将会陷入恐慌。"
        },
        {
            "id": "6",
            "content": "理智値到達下限的罪人会被E.G.O侵蝕。"
        },
        {
            "id": "7",
            "content": "被E.G.O侵蝕的罪人会无差別地進行攻撃，請多加留意。"
        },
        {
            "id": "8",
            "content": "状態效果的強度决定了其会造成多少傷害。"
        },
        {
            "id": "9",
            "content": "技能在使用后会轉化成対應属性的E.G.O資源。"
        },
        {
            "id": "10",
            "content": "多次撃敗同一个異想体可以提升対其的観察等級，之后再次与之戦斗時造成的傷害也会随之提高。"
        },
        {
            "id": "11",
            "content": "需要消耗資源的技能会在資源不足時被取消，還請多加留意。"
        },
        {
            "id": "12",
            "content": "速度値会在每回合開始時从人格信息所示的范圍内随机决定。"
        },
        {
            "id": "13",
            "content": "速度値决定了敵我双方的角色在戦斗中的站位。"
        },
        {
            "id": "14",
            "content": "戦斗開始時，罪人的罪孼抗性為其所装備最低等級E.G.O的抗性。"
        },
        {
            "id": "15",
            "content": "使用E.G.O后，罪人的罪孼抗性将会変為所用E.G.O的抗性。"
        },
        {
            "id": "16",
            "content": "守備技能会固定生成到儀表盤最下方的行動槽，且会替換槽位中的技能或E.G.O。"
        },
        {
            "id": "17",
            "content": "在E.G.O使用之前将其取消会返還其消耗的E.G.O資源。"
        },
        {
            "id": "18",
            "content": "連接了2个及以上的同属性技能時，将会激活罪孼共鳴，并強化参与共鳴的技能。"
        },
        {
            "id": "19",
            "content": "連續連接了3个及以上的同属性技能時，将会激活完全共鳴，并強化参与共鳴的技能。"
        },
        {
            "id": "20",
            "content": "進行拼点的次数越多，拼点結束后獲勝方的傷害倍率就越高。"
        },
        {
            "id": "21",
            "content": "当角色的体力降至混乱閾値之下時，其対所有攻撃類型的抗性都会変為致命，且在下回合結束前无法行動。"
        },
        {
            "id": "22",
            "content": "在迷宮里，宁可以在存档点恢復所有罪人的状態并保存進度。"
        },
        {
            "id": "23",
            "content": "所有人格都擁有一个戦斗被動技能和一个支援被動技能。"
        },
        {
            "id": "24",
            "content": "参与戦斗的人格可以使用戦斗被動技能。"
        },
        {
            "id": "25",
            "content": "場下的罪人通過其支援被動技能来輔助戦斗。"
        },
        {
            "id": "26",
            "content": "異想体的不同部位可能会有不同的抗性，使用不同的技能。"
        },
        {
            "id": "27",
            "content": "在集中遭遇戦時，宁可能会遇到需要進行决断的情况;根据决断的結果，宁可以獲得各種各様的效果，甚至可以獲得E.G.O飾品。"
        },
        {
            "id": "28",
            "content": "未擁有特定罪孼属性的技能也依然有可能通過判定。"
        },
        {
            "id": "29",
            "content": "在迷宮探索中，戦斗和事件都可以獲得E.G.O飾品。"
        },
        {
            "id": "30",
            "content": "当敵人的理智値被消耗至陷入恐慌時，他們将会受到各種負面状態的影響。"
        },
        {
            "id": "31",
            "content": "若一个角色在陷入混乱后体力降至下一个混乱閾値之下，其受到的傷害将会変得更高。"
        },
        {
            "id": "32",
            "content": "状態效果的層数决定了效果的生效時長或生效次数。"
        },
        {
            "id": "33",
            "content": "E.G.O技能将会固定生成在儀表盤最下方的行動槽。"
        },
        {
            "id": "34",
            "content": "使用攻撃技能対峙時，将会進行拼点。"
        },
        {
            "id": "35",
            "content": "戦斗被動以及支援被動需要通過鏈接或持有特定罪孼才可以触発。"
        }
    ]
}