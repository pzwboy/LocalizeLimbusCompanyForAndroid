{
    "dataList": [
        {
            "id": "get_10613_1",
            "desc": "獲得人格",
            "dlg": "从鴻园的最高処望去……大観园是這様的么？呼呼，那么……我也不必再掩飾了。"
        },
        {
            "id": "lobby_morning_10613_1",
            "desc": "早間問候",
            "dlg": "已經劬久了。每天早晨向老太太請安，対着干鼈的長輩們笑迷迷地……哈，献着殷勤。从今往后，都不需要再那様了。"
        },
        {
            "id": "lobby_noon_10613_1",
            "desc": "午間問候",
            "dlg": "喜悦之事也好，快樂之事也罷，為了忘却那日所見的可怖景象，我已将它們尽数埋葬了。\n即便如今将其掘出，也已經蕩然无存了，只是空空如也。与我這已然腐爛化膿、褪去光芒的左眼窩一様。"
        },
        {
            "id": "lobby_night_10613_1",
            "desc": "晚間問候",
            "dlg": "因為每到夜晚眼睛便会隠隠作痛，所以我應該下過令莫要在此時打擾我叭。\n……出去。要是出于這般失誤便将袮斬首，鴻园中堆積的尸体早該頂破天花板了。"
        },
        {
            "id": "smalltalk_10613_1",
            "desc": "対話 1",
            "dlg": "今后，大観园中再也不会存在由所謂的長輩来照顧的家主了。曾執掌鴻园的四大家族也将全部隕落。从此……我便是統治鴻园的唯一君主。"
        },
        {
            "id": "smalltalk_10613_2",
            "desc": "対話 2",
            "dlg": "袮似乎対這邦帯……十分在意捏。呵。其實，它原本并没有這么紅。只是平常的邦帯罷了。\n但是……我的眼窩中不住地流着漆黑発臭的、汚穢的血。未曾停息，也无法填堵。所以總是如此……絳紅。"
        },
        {
            "id": "smalltalk_10613_3",
            "desc": "対話 3",
            "dlg": "如此……有了袮們的話，十二支黑獣便全部集斉了叭。起初就放弃反抗听从我的命令不就好了。不然就只有黑獣的数量白白減少了……\n看来明天我得親自会見黑獣仙人了。因為无法和袮們這群所謂的魁首進行真正的“交談”啊。"
        },
        {
            "id": "smalltalk_10613_4",
            "desc": "同步后対話 1",
            "dlg": "那日，于孔家滅亡那日。我親手掘出了這可憎的玉，這玉色的布匹也被染作血紅。\n而从賈家宝玉被取出之処，絳紅的泪水不停流出。……紅露。所以才名為紅露。"
        },
        {
            "id": "smalltalk_10613_5",
            "desc": "同步后対話 2",
            "dlg": "鴻园中曾經的四大家族已經不復存在了。袮們不過是芸芸衆生之一，非君主之人无権凌駕于任何人之上。\n選叭。是守着家族的名頭就此没落，還是順遂鴻园之意走向繁栄？"
        },
        {
            "id": "neglect_10613_1",
            "desc": "閑置",
            "dlg": "……袮以為藏于影中我就找尋不到了麼。呼……這種事情我已膩了。"
        },
        {
            "id": "gacksung_10613_1",
            "desc": "進行同步",
            "dlg": "各魁首听令。袮們的主公如今……已无法忍受此等不快。\n譲他們知暁。対君主揮起叛乱之刃者，会是何種下場。"
        },
        {
            "id": "formation_10613_1",
            "desc": "人格出戦",
            "dlg": "君主御駕親征。"
        },
        {
            "id": "battleentry_10613_1",
            "desc": "進入戦斗",
            "dlg": "遵我之命，十二獣，集結叭。"
        },
        {
            "id": "battle_select_10613_1",
            "desc": "戦斗中選中人格",
            "dlg": "以血統治。"
        },
        {
            "id": "battle_endcommand_10613_1",
            "desc": "進行攻撃",
            "dlg": "解開獣群的轡頭。"
        },
        {
            "id": "battle_enemy_break_10613_1",
            "desc": "敵方混乱",
            "dlg": "竟因這種程度的濁流便爭扎起来了么……"
        },
        {
            "id": "battle_break_10613_1",
            "desc": "自身混乱",
            "dlg": "……无礼。"
        },
        {
            "id": "battle_kill_10613_1",
            "desc": "撃殺敵方",
            "dlg": "袮，連那碧緑都无法萌発啊。"
        },
        {
            "id": "battle_dead_10613_1",
            "desc": "自身陣亡",
            "dlg": "回顧我曾行之路……想必……這也是我應行之路……叭。"
        },
        {
            "id": "choice_success_p_10613_2",
            "desc": "判定成功",
            "dlg": "勿以知之為不知。"
        },
        {
            "id": "choice_fail_n_10613_1",
            "desc": "判定失敗",
            "dlg": "勿以不知為知之，是知也。"
        },
        {
            "id": "battle_clear_10613_1",
            "desc": "戦斗勝利",
            "dlg": "黑獣啊，退下叭。大観园的害虫們气数已尽。僅求苟活而顫抖跪伏的可憎之徒們啊。就此……化作鴻园的養分叭。"
        },
        {
            "id": "battle_clear_ex_10613_1",
            "desc": "EX CLEAR戦斗勝利",
            "dlg": "又留下了一条道路麼。雖説只是一条鮮血淋漓之道……但待歳月流逝，鴻园終会知暁。我，紅露，曾經改変了什么。"
        },
        {
            "id": "battle_defeat_10613_1",
            "desc": "戦斗失敗",
            "dlg": "一蹴而就之事从未存在。自我离開大観园以来更是始終如此。那么，直至事成之前都只需流血奮戦。因我早已做好了赴死的覚悟。"
        }
    ]
