{
    "dataList": [
        {
            "id": 0,
            "model": "홍루",
            "content": "<i><color=#5bffde>階前愁殺葬花人</i></color>",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 1,
            "model": "홍루",
            "content": "<i><color=#5bffde>独倚花鋤泪暗洒</i></color>",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 2,
            "model": "홍루",
            "content": "<i><color=#5bffde>洒上空枝見血痕</i></color>",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 3,
            "model": "홍루",
            "content": "<i><color=#5bffde>昨宵庭外悲歌発</i></color>",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 4,
            "model": "홍루",
            "content": "<i><color=#5bffde>知是花魂与鳥魂</i></color>",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 5,
            "model": "홍루",
            "content": "<i><color=#5bffde>惜春春去難挽留</i></color>",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 6,
            "model": "홍루",
            "content": "<i><color=#5bffde>几多泣声只相聞</i></color>",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 7
        },
        {
            "id": 8,
            "content": "<color=#9a2d30>現在明白了麼，袮什么都做不到。</color>"
        },
        {
            "id": 9,
            "content": "<color=#9a2d30>所以……</color>"
        },
        {
            "id": 10,
            "place": "鴻园 某処",
            "content": "在无風拂過的沙地上……"
        },
        {
            "id": 11,
            "content": "像是被試圖将一切事物摧毀殆尽的明確惡意肆虐過一般，僅剩一座惨不忍睹的建筑得以留存。"
        },
        {
            "id": 12,
            "content": "<i>勿忘孔家滅門之日。</i>"
        },
        {
            "id": 13,
            "content": "<i>\n滅門皆因孔家罪孼深重。</i>"
        },
        {
            "id": 14,
            "content": "<i>\n対其未能遵守鴻园戒律之罪業，无需悲憫，只應感到可笑。</i>"
        },
        {
            "id": 15,
            "content": "<i>\n因此，报應必当降至其身。</i>"
        },
        {
            "id": 16,
            "model": "이스마엘",
            "content": "那么，這里就是……",
            "teller": "以實瑪利",
            "title": "8号罪人"
        },
        {
            "id": 17,
            "model": "이스마엘",
            "content": "那个已經滅門的孔家的……建筑麼？",
            "teller": "以實瑪利",
            "title": "8号罪人"
        },
        {
            "id": 18,
            "content": "以實瑪利読了読建筑前的看板上写的警告，回頭向鴻璐問道。"
        },
        {
            "id": 19,
            "place": "孔家建筑的廃墟",
            "model": "홍루",
            "content": "是的，没錯。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 20,
            "model": "홍루",
            "content": "現在這里已經被廃弃了。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 21,
            "model": "싱클레어",
            "content": "那么，曾在這里面的所有人都……",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 22,
            "model": "그레고르",
            "content": "……",
            "teller": "格里高尓",
            "title": "13号罪人"
        },
        {
            "id": 23,
            "model": "싱클레어",
            "content": "到底犯下了多重的罪……才会做到這種地步？",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 24,
            "model": "오티스",
            "content": "這等規模的建筑徹底淪為了廃墟……意味着這并非帮派或收尾人間的冲突造成的。應該是発生了……近乎戦争規模的事件。",
            "teller": "奥提斯",
            "title": "12号罪人"
        },
        {
            "id": 25,
            "model": "홍루",
            "content": "是的。即使是在都市里也很難見到這幅光景叭。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 26,
            "model": "홍루",
            "content": "畢竟首脳来到了這里。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 27,
            "content": "像是簡単地解答出了復雑的謎題一様，鴻璐的回答十分自然。"
        },
        {
            "id": 28,
            "model": "파우스트",
            "content": "……",
            "teller": "浮士德",
            "title": "2号罪人"
        },
        {
            "id": 29,
            "model": "싱클레어",
            "content": "首脳……麼。",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 30,
            "model": "이스마엘",
            "content": "所以是犯下了禁忌麼。孔家的人們……",
            "teller": "以實瑪利",
            "title": "8号罪人"
        },
        {
            "id": 31,
            "model": "홍루",
            "content": "……那之后清道夫們進行了事后処理。為了譲与禁忌有関的一切都蕩然无存。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 32,
            "content": "首脳……這个団体一定相当恐怖。正当罪人們大多面露難色，各自開始埃声嘆气時。"
        },
        {
            "id": 33,
            "model": "사회자",
            "content": "歓迎各位成功進入第二輪評審的候選人們！",
            "teller": "主持人",
            "title": "大観园"
        },
        {
            "id": 34,
            "content": "从不知安在何処的揚声器中突然傳出了響亮的声音。"
        },
        {
            "id": 35,
            "model": "사회자",
            "content": "在積極听取了各式各様与公平性相関的意見后，最終决定由我担任第二輪評審的新主持人，還請各位理解……",
            "teller": "主持人",
            "title": "大観园"
        },
        {
            "id": 36,
            "content": "……看様子賈政被敢下主持人之位了。"
        },
        {
            "id": 37,
            "model": "히스클리프",
            "content": "喂，等会……上頭的那些……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 38,
            "model": "히스클리프",
            "content": "哈……難道是観衆麼？",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 39,
            "content": "一无所剩的建筑頂端有一个烏泱泱坐満了人的観衆席。"
        },
        {
            "id": 40,
            "model": "파우스트",
            "content": "从連椅子都配置好了這点来看，他們應該確實是観衆。",
            "teller": "浮士德",
            "title": "2号罪人"
        },
        {
            "id": 41,
            "model": "사회자",
            "content": "雖然第一輪評審中出現了一点小小的騒動，但我們下次旁観家主評審又要等到何時捏？",
            "teller": "主持人",
            "title": "大観园"
        },
        {
            "id": 42,
            "model": "사회자",
            "content": "如此罕見的活動，観衆自然是越多越好。",
            "teller": "主持人",
            "title": "大観园"
        },
        {
            "id": 43,
            "model": "사회자",
            "content": "来！在正式開始之前，請大家為全力備戦的候選人們致以熱烈的掌声！",
            "teller": "主持人",
            "title": "大観园"
        },
        {
            "id": 44,
            "teller": "観衆們",
            "title": "大観园",
            "content": "好挨！！"
        },
        {
            "id": 45,
            "model": "히스클리프",
            "content": "什么呀，乱七八糟的。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 46,
            "model": "히스클리프",
            "content": "這是打算譲上面那些家夥吃着点心，欣賞我們在下面拼死拼活的様子麼？",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 47,
            "model": "홍루",
            "content": "應該還会打賭叭。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 48,
            "model": "홍루",
            "content": "雖然估計几乎不会有賭我們贏的人叭~",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 49,
            "model": "료슈",
            "content": "他們会后悔的。",
            "teller": "良秀",
            "title": "4号罪人"
        },
        {
            "id": 50,
            "model": "이스마엘",
            "content": "不過……這里應該是室内叭？我記得我們是下降到了地下，可這藍天……像是突然到了外面一様……",
            "teller": "以實瑪利",
            "title": "8号罪人"
        },
        {
            "id": 51,
            "content": "雖然鴻璐已經説過……這里還是鴻园的地下。"
        },
        {
            "id": 52,
            "content": "但在電梯門打開后映入眼帘的湛藍天空，還是令大多罪人感到難以置信。"
        },
        {
            "id": 53,
            "model": "파우스트",
            "content": "在鴻园内，唯有富人階層可以根据喜好，人為地布置房間。而在大観园中，也已經存在几座根据房間主人興趣装飾的建筑。",
            "teller": "浮士德",
            "title": "2号罪人"
        },
        {
            "id": 54,
            "model": "홍루",
            "content": "没錯，去面見長輩們的路上也是這様装飾的。整条道路總是晴空万里，緑意昂然哦。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 55,
            "model": "홍루",
            "content": "可以説是比外界更像是外界叭。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 56,
            "model": "로쟈",
            "content": "順帯一問……那是什么？",
            "teller": "羅佳",
            "title": "9号罪人"
        },
        {
            "id": 57,
            "content": "順着羅佳的視綫望去，那里突兀地留着一張像是誰曾在下方休息過一般的老旧遮陽傘。"
        },
        {
            "id": 58,
            "model": "홍루",
            "content": "啊，那是遮陽傘。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 59,
            "model": "로쟈",
            "content": "遮……遮陽傘我当然認得……我問的是為什么那个廃品似的遮陽傘還留在那辺……",
            "teller": "羅佳",
            "title": "9号罪人"
        },
        {
            "id": 60,
            "model": "홍루",
            "content": "唔……",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 61,
            "content": "鴻璐歪起頭思考了片刻。"
        },
        {
            "id": 62,
            "model": "홍루",
            "content": "帯来爪牙的那位大人物曾在那里見証了一切。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 63,
            "model": "홍루",
            "content": "所以，四大家族特地保留了那柄遮陽傘的原因是……",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 64,
            "model": "홍루",
            "content": "希望能劬長久銘記。也是為了展示給所有家族作為警告。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 65,
            "model": "싱클레어",
            "content": "銘記？……要銘記什么？",
            "teller": "辛克莱",
            "title": "11号罪人"
        },
        {
            "id": 66,
            "model": "홍루",
            "content": "不應渴望未被應允之事。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 67,
            "model": "홍루",
            "content": "人当應天而生，順天而逝。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 68,
            "model": "홍루",
            "content": "……長輩們是這么説的。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 69,
            "model": "홍루",
            "content": "是時候進去了叭？",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 70,
            "content": "正当大家迷惑不解時……"
        },
        {
            "id": 71,
            "content": "只有鴻璐駕輕就熟地向建筑内走去。"
        },
        {
            "id": 72,
            "model": "단테",
            "content": "<雖然説是从長輩們那里听来的……>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 73,
            "model": "단테",
            "content": "<但袮實際上看到了叭……？那一切。>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 74,
            "content": "走在前方的鴻璐轉身面向我們。"
        },
        {
            "id": 75,
            "model": "홍루",
            "content": "……",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 76,
            "model": "홍루",
            "content": "是啊，也許叭。",
            "teller": "鴻璐",
            "title": "6号罪人"
        },
        {
            "id": 77,
            "content": "即使是我，現在也漸漸読不憧鴻璐臉上那副笑容的含義了。"
        }
    ]
}