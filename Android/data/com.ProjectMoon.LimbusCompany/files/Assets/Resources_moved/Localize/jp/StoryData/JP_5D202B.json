{
    "dataList": [
        {
            "id": 0,
            "place": "白鯨的右心房",
            "model": "퀴케그",
            "content": "那个。既非人魚，也非鯨。是郊区的怪物麼？",
            "teller": "魁魁格",
            "title": "裴廓德鎮"
        },
        {
            "id": 1,
            "model": "파우스트",
            "content": "它們被称作異想体。它們曾收容于脳叶公司支部，但被這頭鯨呑下去了。",
            "teller": "浮士德",
            "title": "2号罪人"
        },
        {
            "id": 2,
            "model": "퀴케그",
            "content": "我見過，相似的東西。但不是，異想体。",
            "teller": "魁魁格",
            "title": "裴廓德鎮"
        },
        {
            "id": 3,
            "model": "파우스트",
            "content": "確實，在郊区遇到什么都不奇怪。所以袮完全有可能遇到類似異想体的實体。",
            "teller": "浮士德",
            "title": "2号罪人"
        },
        {
            "id": 4,
            "model": "퀴케그",
            "content": "異想体。是如何，誕生的？",
            "teller": "魁魁格",
            "title": "裴廓德鎮"
        },
        {
            "id": 5,
            "model": "파우스트",
            "content": "它們都曾是人類。它們被人為制造出来，用于生産新型能源。",
            "teller": "浮士德",
            "title": "2号罪人"
        },
        {
            "id": 6,
            "model": "퀴케그",
            "content": "他們似乎。有愿望。",
            "teller": "魁魁格",
            "title": "裴廓德鎮"
        },
        {
            "id": 7,
            "model": "파우스트",
            "content": "袮是在問異想体……是否有特定的欲望和需求麼。",
            "teller": "浮士德",
            "title": "2号罪人"
        },
        {
            "id": 8,
            "model": "퀴케그",
            "content": "它們知道，自我麼？自己想要的。和所希望的。",
            "teller": "魁魁格",
            "title": "裴廓德鎮"
        },
        {
            "id": 9,
            "model": "그레고르",
            "content": "不過，看上去它們也只剩下那些欲望和需求了。",
            "teller": "格里高尓",
            "title": "13号罪人"
        },
        {
            "id": 10,
            "model": "퀴케그",
            "content": "……",
            "teller": "魁魁格",
            "title": "裴廓德鎮"
        },
        {
            "id": 11,
            "model": "퀴케그",
            "content": "真令人羨慕。",
            "teller": "魁魁格",
            "title": "裴廓德鎮"
        },
        {
            "id": 12,
            "model": "퀴케그",
            "content": "完全知暁。自己想要什么……",
            "teller": "魁魁格",
            "title": "裴廓德鎮"
        },
        {
            "id": 13,
            "content": "魁魁格一辺望着異想体，一辺不停地抓撓着自己的骼膊。"
        },
        {
            "id": 14,
            "content": "他抓得實在太用力了，以至于血液混合着蒼白的黏液从傷口処滴落而下。"
        },
        {
            "id": 15,
