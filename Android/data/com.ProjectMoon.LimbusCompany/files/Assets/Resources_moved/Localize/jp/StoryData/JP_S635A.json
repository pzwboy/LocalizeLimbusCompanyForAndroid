            "model": "단테",
            "content": "<清醒了麼，希斯克利夫？>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 1,
            "model": "히스클리프다침",
            "content": "……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 2,
            "model": "이스마엘",
            "content": "……感覚如何？",
            "teller": "以實瑪利",
            "title": "8号罪人"
        },
        {
            "id": 3,
            "model": "히스클리프다침",
            "content": "像屎一様。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 4,
            "model": "히스클리프다침",
            "content": "還很痛苦。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 5,
            "model": "히스클리프다침",
            "content": "這些尸体，還有袮們身上的傷口……都是我干的麼？",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 6,
            "content": "希斯克利夫看見凄惨地倒在地上的研究員們的尸体，低声喃喃道。"
        },
        {
            "id": 7,
            "model": "히스클리프다침",
            "content": "真奇怪。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 8,
            "model": "히스클리프다침",
            "content": "這次還以為如果将一切全都匝爛……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 9,
            "model": "히스클리프다침",
            "content": "我就会痛快許多。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 10,
            "model": "히스클리프다침",
            "content": "但這次却不是那様。反倒覚得特別糟羔。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 11,
            "model": "히스클리프다침",
            "content": "我変得和亨德利那家夥，没什么区別了叭。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 12,
            "model": "히스클리프다침",
            "content": "只是一心想要把面前的所有東西全部匝碎……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 13,
            "model": "히스클리프다침",
            "content": "最可怕的是……我曾想一直保持那種状態。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 14,
            "model": "히스클리프다침",
            "content": "要説為什么……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 15,
            "model": "히스클리프다침",
            "content": "那只是因為，我不能忍受一味等待罷了。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 16,
            "model": "단테",
            "content": "<袮和他不一様。>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 17,
            "model": "단테",
            "content": "<袮啊，最終変回来了捏。>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 18,
            "model": "히스클리프다침",
            "content": "……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 19,
            "model": "히스클리프다침",
            "content": "這次雖然変回来了，但下次捏？誰能保証我不会再変成這様捏？",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 20,
            "model": "히스클리프다침",
            "content": "也許亨德利那家夥是対的。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 21,
            "model": "히스클리프다침",
            "content": "我从出生開始就是一个錯誤，自己已經改変不過是一種可笑的錯覚……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 22,
            "model": "히스클리프다침",
            "content": "像這様勃然大怒，不把一切破坏殆尽誓不罷休，才是我真正的模様。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 23,
            "model": "단테",
            "content": "<……>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 24,
            "model": "단테",
            "content": "<我不能保証。但是……我們会再次譲袮復原的。>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 25,
            "model": "히스클리프다침",
            "content": "哈……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 26,
            "model": "히스클리프다침",
            "content": "喂，鐘表頭。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 27,
            "model": "히스클리프다침",
            "content": "雖然袮大概不知道……但除了袮以外，大家應該都知道叭。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 28,
            "model": "히스클리프다침",
            "content": "当我失去理智，眼前被黑暗蒙蔽之時，總而言之……当我什么也看不到，什么也听不見之時……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 29,
            "model": "히스클리프다침",
            "content": "当就這様下去，我整个人就要消失在黑暗之中的時候……",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 30,
            "model": "히스클리프다침",
            "content": "我能听見一个很微弱的声音。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 31,
            "model": "히스클리프다침",
            "content": "那个煩人的鐘表声。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 32,
            "model": "히스클리프다침",
            "content": "于是我再度睜開了双眼，于是我再度被拉回現實。",
            "teller": "希斯克利夫",
            "title": "7号罪人"
        },
        {
            "id": 33,
            "model": "단테",
            "content": "<那是……>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 34,
            "model": "단테",
            "content": "<将袮們帯回原本的道路，是我作為經理的職責所在。>",
            "teller": "但丁",
            "title": "執行經理"
        },
        {
            "id": 35,
            "content": "当我用言語表達后，才清楚地明白了。"
        },
        {
            "id": 36,
            "content": "我的鐘表声喚醒了他們，从而譲他們回帰到原本的道路上。"
        },
        {
            "id": 37,
            "content": "雖然我不知道原本的道路究竟是什么，又到底該怎么走下去……"
        },
        {
            "id": 38,
            "content": "尽管如此，我們依旧前行。"
        },
        {
            "id": 39,
            "content": "如同沿着牆壁摸索，就能某種程度上掌握迷宮的輪廓那様。"
        }
    ]
