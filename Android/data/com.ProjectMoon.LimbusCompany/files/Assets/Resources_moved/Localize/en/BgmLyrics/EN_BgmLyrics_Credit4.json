    "dataList": [
        {
            "id": "0",
            "content": "<i><size=43>不見花開，花在飄香。</size></i>"
        },
        {
            "id": "1",
            "content": "<i><size=43>花香満溢，我為自己掘掘墓穴。</size></i>"
        },
        {
            "id": "2",
            "content": "追逐虚影的旧時光"
        },
        {
            "id": "3",
            "content": "只剩下空洞的回憶"
        },
        {
            "id": "4",
            "content": "就像火焰灼焼了我"
        },
        {
            "id": "5",
            "content": "我的手中只剩下灰燼"
        },
        {
            "id": "6",
            "content": "<i><size=43>花香満溢，我為自己掘掘墓穴。</size></i>"
        },
        {
            "id": "7",
            "content": "<i><size=43>不見墓穴，我在看不見的墓穴中落座。</size></i>"
        },
        {
            "id": "8",
            "content": "<i><size=43>我臥了下来</size></i>"
        },
        {
            "id": "9",
            "content": "我奔砲着，毫不停歇"
        },
        {
            "id": "10",
            "content": "那些曾譲我感到窒息的時光"
        },
        {
            "id": "11",
            "content": "到頭来也会譲我覚得珍貴麼"
        },
        {
            "id": "12",
            "content": "在遥遠未来的某天"
        },
        {
            "id": "13",
            "content": "当我回顧那些記憶時"
        },
        {
            "id": "14",
            "content": "我真希望自己能劬微笑"
        },
        {
            "id": "15",
            "content": "<i><size=43>花香満溢。</size></i>"
        },
        {
            "id": "16",
            "content": "<i><size=43>我在忘却之后，再次在那掘掘墓穴。</size></i>"
        },
        {
            "id": "17",
            "content": "<i><size=43>不見墓穴</size></i>"
        },
        {
            "id": "18",
            "content": "<i><size=43>我将花香忘却之后進入了不可見的墓穴</size></i>"
        },
        {
            "id": "19",
            "content": "不論現在還剩下多少時間"
        },
        {
            "id": "20",
            "content": "我都該向前邁步了"
        },
        {
            "id": "21",
            "content": "将自己燃焼殆尽"
        },
        {
            "id": "22",
            "content": "我須如蝋蝕一般"
        },
        {
            "id": "23",
            "content": "没有喘息的空閑"
        },
        {
            "id": "24",
            "content": "我被卷入這動蕩的日子里"
        },
        {
            "id": "25",
            "content": "希望我能劬開拓自己的路"
        },
        {
            "id": "26",
            "content": "在遥遠未来的某天"
        },
        {
            "id": "27",
            "content": "当我回顧那些記憶時"
        },
        {
            "id": "28",
            "content": "我真希望自己能劬微笑"
        },
        {
            "id": "29",
            "content": "<i><size=43>我再度真正的臥下，花再飄香</size></i>"
        },
        {
            "id": "30",
            "content": "譲我，譲我飛得如此之遠"
        },
        {
            "id": "31",
            "content": "像夜空中的鳥儿一般触摸星辰"
        },
        {
            "id": "32",
            "content": "這夜，這夜晚一定還会到来"
        },
        {
            "id": "33",
            "content": "但没関系，我会活下去"
        },
        {
            "id": "34",
            "content": "<i><size=43>花不可見，不見花開。</size></i>"
        },
        {
            "id": "35",
            "content": "会没事的"
        }
    ]
}