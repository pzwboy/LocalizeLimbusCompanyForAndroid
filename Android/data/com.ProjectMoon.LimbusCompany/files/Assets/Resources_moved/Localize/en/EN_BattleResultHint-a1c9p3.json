{
    "dataList": [
        {
            "id": "battleTip_none",
            "content": "(더미)"
        },
        {
            "id": "battleTip_10937_1",
            "content": "請注意不要譲霍恩海姆与阿莉莎比罪人更早被撃敗。"
        },
        {
            "id": "battleTip_10937_2",
            "content": "應対環指父輩的技能時，最好専注于必須拼点勝利的技能。"
        },
        {
            "id": "battleTip_10937_3",
            "content": "環指父輩与子輩的強力攻撃，可在進行拼点前用其他方法弱化。"
        },
        {
            "id": "battleTip_10943_1",
            "content": "推荐使用相対容易拼点勝利的技能来進行拼点。"
        },
        {
            "id": "battleTip_10943_2",
            "content": "推荐優先撃殺体力較低的敵方単位。"
        },
        {
            "id": "battleTip_10938_1",
            "content": "父輩是罪人難以應対的敵人。"
        },
        {
            "id": "battleTip_10938_2",
            "content": "活用韋斯帕和以斯拉的援護防御很重要。"
        },
        {
            "id": "battleTip_10942_phase1_1",
            "content": "拇指子輩使用強力技能前，請譲其他罪人先与其進行拼点，以弱化其技能。"
        },
        {
            "id": "battleTip_10942_phase1_2",
            "content": "需要将拇指子輩的体力減少至一半以下。"
        },
        {
            "id": "battleTip_10942_phase2_1",
            "content": "拇指子輩会妨碍援助単位的攻撃。\n推荐譲罪人優先攻撃拇指子輩。"
        },
        {
            "id": "battleTip_10942_phase2_2",
            "content": "拇指父輩受到攻撃時，会消耗預知眼使用閃避技能。\n活用援助単位持續消耗拇指父輩的預知眼很重要。"
        },
        {
            "id": "battleTip_10942_phase2_3",
            "content": "拇指父輩的強力技能无法改変攻撃目標。\n該技能会根据預知眼的消耗而弱化，因此在技能発動前尽可能地消耗預知眼很重要。"
        },
        {
            "id": "battleTip_10944_1",
            "content": "活用韋斯帕和以斯拉的援護防御很重要。"
        },
        {
            "id": "battleTip_10944_2",
            "content": "請策略性地把握能用単方面攻撃使敵人混乱的時机。"
        },
        {
            "id": "battleTip_10944_3",
            "content": "当敵人陷入絶境并変強時，不應勉強与其拼点，而應専心防守，等待援助単位秘藏的一招。"
        },
        {
            "id": "battleTip_10945_1",
            "content": "蜚蠊皇帝与罪人拼点勝利次数越多就会変得越弱。\n但是，譲罪人承受所有攻撃是非常危険的。"
        },
        {
            "id": "battleTip_10945_2",
            "content": "“攻撃害虫[蜚蠊]”積累過多時，使蜚蠊皇帝的技能“皇帝的捕食”命中可以降低其層数。"
        },
        {
            "id": "battleTip_10945_3",
            "content": "蜚蠊皇帝的擁有截除硬幣的技能，在目標是擁有不可摧毀的硬幣的技能時，会変得極其強大。"
        },
        {
            "id": "battleTip_10941_1",
            "content": "確認可与技能“已確定的対手”拼点的罪人，使用合适的攻撃技能累積対小指父輩的傷害。"
        },
        {
            "id": "battleTip_10941_2",
            "content": "根据情况判断應該優先与小指父輩的那个技能進行拼点，随机應変很重要。"
        },
        {
            "id": "battleTip_10948_1",
            "content": "戦斗中我方処于優勢時，小指父輩会更具攻撃性，\n我方処于劣勢時，他則会采取防御性行動。"
        },
        {
            "id": "battleTip_10948_2",
            "content": "請制定能劬承受小指父輩攻撃的策略，并不断累積対其的傷害。"
        },
        {
            "id": "battleTip_10949_1",
            "content": "在撃敗食指子輩与小指子輩前，請注意不要譲默尓索和奥提斯先行死亡。"
        },
        {
            "id": "battleTip_10949_2",
            "content": "良秀每回合都会攻撃食指子輩或小指子輩中的一人。"
        },
        {
            "id": "battleTip_10949_3",
            "content": "每回合引導良秀専注應対一名子輩，\n同時譲罪人去攻略令一名子輩的方式更有利。"
        },
        {
            "id": "battleTip_10950_1",
            "content": "食指父輩在執行指令失敗時，会対自身施加業。随着業的増加，食指父輩包含拼点威力在内的整体能力都会有所下降。"
        },
        {
            "id": "battleTip_10950_2",
            "content": "在特殊模式中，需要拼点威力較高的斬撃、突刺、打撃技能以應対。建議准備具備這些属性的高拼点威力E.G.O技能。"
        },
        {
            "id": "battleTip_10950_3",
            "content": "食指父輩在体力較低時使用的強力技能威力極高。此時可使用良秀的基礎E.G.O“森羅炎象”進行應対。"
        }
    ]
}