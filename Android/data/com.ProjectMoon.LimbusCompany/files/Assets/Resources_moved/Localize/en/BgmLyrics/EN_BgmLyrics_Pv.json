  "dataList": [
    {
      "id": "0",
      "content": "……啧。"
    },
    {
      "id": "1",
      "content": "出发咯，布隆布隆。"
    },
    {
      "id": "2",
      "content": "向地狱出发吧。"
    },
    {
      "id": "3",
      "content": "我走下一条路径"
    },
    {
      "id": "4",
      "content": "带我回到過去"
    },
    {
      "id": "5",
      "content": "掰開树木之手，盗走一顆"
    },
    {
      "id": "6",
      "content": "那是後悔者的好友——禁断之果"
    },
    {
      "id": "7",
      "content": "我咬下它的果皮\n咀嚼它水嫩的果肉"
    },
    {
      "id": "8",
      "content": "咽下它温暖的脓水"
    },
    {
      "id": "9",
      "content": "你成為了你最厌悪的【我】"
    },
    {
      "id": "10",
      "content": "我们吞噬时間\n倒带"
    },
    {
      "id": "11",
      "content": "喇们\n如果你想譲我持続存活"
    },
    {
      "id": "12",
      "content": "如果你想譲我宽恕原諒"
    },
    {
      "id": "13",
      "content": "如果你想譲我们假装扮演文明社会的住人"
    },
    {
      "id": "14",
      "content": "当我们死于一次又一次輪回\n（当我们死于一次又一次輪回）"
    },
    {
      "id": "15",
      "content": "我心中的正义，\n那个為我狡弁的自我使我的罪悪合理化"
    },
    {
      "id": "16",
      "content": "喇们\n為什么唯有死才能终结我受到的拷打？"
    },
    {
      "id": "17",
      "content": "為什么誰也无法理解我的悲苦？"
    },
    {
      "id": "18",
      "content": "為什么戴冠的王者终归是最暴力凶残的那一个？"
    },
    {
      "id": "19",
      "content": "這是炼狱\n（炼狱）"
    },
    {
      "id": "20",
      "content": "我们為各自建起的炼狱"
    },
    {
      "id": "21",
      "content": "我们相互复苏，存于地狱之中"
    }
  ]
}