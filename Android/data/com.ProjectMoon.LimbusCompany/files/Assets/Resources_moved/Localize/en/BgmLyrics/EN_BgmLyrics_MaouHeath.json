    {
      "id": 0,
      "content": "<style=\"djp_CP6_2\">我多么希望能够拥有",
      "vocalid": 0
    },
    {
      "id": 1,
      "content": "<style=\"djp_CP6_2\">一个更加幸福明亮的未来",
      "vocalid": 0
    },
    {
      "id": 2,
      "content": "<style=\"djp_CP6_2\">我站立于大門之前",
      "vocalid": 0
    },
    {
      "id": 3,
      "content": "<style=\"djp_CP6_2\">親爱的過去",
      "vocalid": 0
