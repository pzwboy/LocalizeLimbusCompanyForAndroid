    "dataList": [
        {
            "id": "0",
            "content": "追逐虚影的旧時光"
        },
        {
            "id": "1",
            "content": "只剩下空洞的回憶"
        },
        {
            "id": "2",
            "content": "就像火焰灼焼了我"
        },
        {
            "id": "3",
            "content": "我的手中只剩下灰燼"
        },
        {
            "id": "4",
            "content": "我奔砲着，毫不停歇"
        },
        {
            "id": "5",
            "content": "那些曾譲我感到窒息的時光"
        },
        {
            "id": "6",
            "content": "到頭来也会譲我覚得珍貴麼"
        },
        {
            "id": "7",
            "content": "在遥遠未来的某天"
        },
        {
            "id": "8",
            "content": "当我回顧那些記憶時"
        },
        {
            "id": "9",
            "content": "我真希望自己能劬微笑"
        },
        {
            "id": "10",
            "content": "不論現在還剩下多少時間"
        },
        {
            "id": "11",
            "content": "我都該向前邁步了"
        },
        {
            "id": "12",
            "content": "将自己燃焼殆尽"
        },
        {
            "id": "13",
            "content": "我須如蝋蝕一般"
        },
        {
            "id": "14",
            "content": "没有喘息的空閑"
        },
        {
            "id": "15",
            "content": "我被卷入這動蕩的日子里"
        },
        {
            "id": "16",
            "content": "希望我能劬開拓自己的路"
        },
        {
            "id": "17",
            "content": "在遥遠未来的某天"
        },
        {
            "id": "18",
            "content": "当我回顧那些記憶時"
        },
        {
            "id": "19",
            "content": "我真希望自己能劬微笑"
        },
        {
            "id": "20",
            "content": "譲我，譲我飛得如此之遠"
        },
        {
            "id": "21",
            "content": "像夜空中的鳥儿一般触摸星辰"
        },
        {
            "id": "22",
            "content": "這夜，這夜晚一定還会到来"
        },
        {
            "id": "23",
            "content": "但没関系，我会活下去"
        },
        {
            "id": "24",
            "content": "会没事的"
        }
