{
    "dataList": [
        {
            "id": "get_10510_1",
            "desc": "獲得人格",
            "dlg": "唔，這次的晚自習没有人缺勤。重新積累揮発掉的知識固然可取，但也不要忘記学習新的知識。"
        },
        {
            "id": "lobby_morning_10510_1",
            "desc": "早間問候",
            "dlg": "早上了。不要拉拉拉拉，睜開眼睛后稍稍活動一下身体。\n如果頭脳和身体完全清醒，最好到外面去晒晒太陽，接着便去求知叭。"
        },
        {
            "id": "lobby_noon_10510_1",
            "desc": "午間問候",
            "dlg": "已經是午飯時間了。此時吃得太飽的話会引起睡意。\n一定程度的空腹感能提高集中力。如果袮有之后的日程安排，最好記住。"
        },
        {
            "id": "lobby_night_10510_1",
            "desc": "晚間問候",
            "dlg": "馬上就到孩子們的就寝時間了。睡眠是大脳処理和回顧清醒時收集到的知識的重要学習行為，建議保持安静，不要打擾他們。"
        },
        {
            "id": "smalltalk_10510_1",
            "desc": "対話 1",
            "dlg": "視綫再湊近些。和鑰派們不同，我們是以拳探尋，進而握取知識之人。"
        },
        {
            "id": "smalltalk_10510_2",
            "desc": "対話 2",
            "dlg": "除了하나協会的收尾人考核以外，Dieci協会内令外進行的知識考試也為求知提供了可持續的動机。\n通過考試積累知識，總有一天会謁見圣者大人。"
        },
        {
            "id": "smalltalk_10510_3",
            "desc": "対話 3",
            "dlg": "据記載，南部Dieci協会要用生命守護的圣物，是在很深的廃墟中発現的。\n在北部，東部及西方本部所守護的圣物也是如此。"
        },
        {
            "id": "smalltalk_10510_4",
            "desc": "同步后対話 1",
            "dlg": "是問関于知識揮発后轉換成強大的物理力量的現象麼……\n唔，関于此，現在的我并不知道，也許在這之前我曾知道，但也只是不明知而已。"
        },
        {
            "id": "smalltalk_10510_5",
            "desc": "同步后対話 2",
            "dlg": "積累知識等于積累生存的養分。這是被收養者的天性和規律，不能怠于積累新的知識。\n這也是我常常対不喜歓求知的孩子們説的話。"
        },
        {
            "id": "neglect_10510_1",
            "desc": "閑置",
            "dlg": "忘了来這里的理由了麼？如果忘記了，就應該重新求知。"
        },
        {
            "id": "gacksung_10510_1",
            "desc": "進行同步",
            "dlg": "以纏繞于拳上的這片光輝之布釋放層層積累的知識，将袮碾碎。"
        },
        {
            "id": "formation_10510_1",
            "desc": "人格出戦",
            "dlg": "以拳触触求知的瞬間。"
        },
        {
            "id": "battleentry_10510_1",
            "desc": "進入戦斗",
            "dlg": "只是按照Dieci的教義行事罷了。"
        },
        {
            "id": "battle_select_10510_1",
            "desc": "戦斗中選中人格",
            "dlg": "提問将在任務完成后被接受。"
        },
        {
            "id": "battle_endcommand_10510_1",
            "desc": "進行攻撃",
            "dlg": "這也将成為知識。"
        },
        {
            "id": "battle_enemy_break_10510_1",
            "desc": "敵方混乱",
            "dlg": "因為知識不会永存。"
        },
        {
            "id": "battle_break_10510_1",
