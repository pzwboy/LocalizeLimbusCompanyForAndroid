            "dlg": "唔……"
        },
        {
            "id": "battle_kill_10510_1",
            "desc": "撃殺敵方",
            "dlg": "……不要逃避无知。"
        },
        {
            "id": "battle_dead_10510_1",
            "desc": "自身陣亡",
            "dlg": "我也迎来了……最理所当然的時刻麼……"
        },
        {
            "id": "choice_success_p_10510_2",
            "desc": "判定成功",
            "dlg": "這次做出了正確的選擇。但不知下次是否還会正確。"
        },
        {
            "id": "choice_fail_n_10510_1",
            "desc": "判定失敗",
            "dlg": "也許這是已經被遺忘的知識。錯誤是理所当然的結果。"
        },
        {
            "id": "battle_clear_10510_1",
            "desc": "戦斗勝利",
            "dlg": "先想想遺忘了什么知識。勝利的喜悦在那之后尽情享受也為時不晚。"
        },
        {
            "id": "battle_clear_ex_10510_1",
            "desc": "EX CLEAR戦斗勝利",
            "dlg": "我僅僅是研習戦斗中遺忘的東西与学到的東西，重新積累知識来完成Dieci協会的工作而已。"
        },
        {
            "id": "battle_defeat_10510_1",
            "desc": "戦斗失敗",
            "dlg": "雖然失敗了，但是也能从中獲得知識叭。所以接下来要做的，就是通過那些知識取得勝利。"
        }
