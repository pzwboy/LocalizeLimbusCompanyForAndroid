{
    "dataList": [
        {
            "id": "get_10205_1",
            "desc": "獲得人格",
            "dlg": "浮士德，已收到委托。正在前往保護目標所在地。"
        },
        {
            "id": "lobby_morning_10205_1",
            "desc": "早間問候",
            "dlg": "安全的早晨。今天也会全力保障地区安全。祝宁度過愉快的一天。"
        },
        {
            "id": "lobby_noon_10205_1",
            "desc": "午間問候",
            "dlg": "向宁做出中午的巡察結果没有問題的报告。啊……不用担心午餐的問題。在浮士德享用午餐時，他的同伴会代為巡察。\n啊，那位是4科的人才，所以不必担心。不過還是浮士德更加優秀。"
        },
        {
            "id": "lobby_night_10205_1",
            "desc": "晚間問候",
            "dlg": "在晚上……請尽可能地靠近浮士德。由于視綫変窄，保護移動的速度可能会比白天更慢。"
        },
        {
            "id": "smalltalk_10205_1",
            "desc": "対話 1",
            "dlg": "地区保護是需要大量人力及人員各方面能力的工作。因為必須在簽訂合同的区域全范圍内投入員工。\n為此雖需支付高額的报酬……但可以保証護衛的效果。"
        },
        {
            "id": "smalltalk_10205_2",
            "desc": "対話 2",
            "dlg": "在地区保護任務中，我們会尽可能穿着便衣進行。不顕眼的人才能更容易地找出描准保護対象的勢力。"
        },
        {
            "id": "smalltalk_10205_3",
            "desc": "対話 3",
            "dlg": "并不是所有的Zwei部門都在進行地区保護工作。当然，我們4科也不只有地区保護的業務。"
        },
        {
            "id": "smalltalk_10205_4",
            "desc": "同步后対話 1",
            "dlg": "通常情况下在需要保護的人員較多時会簽訂這種合同。\n因此……我們被要求在衆多敵人面前保護客戸。浮士德也一様。"
        },
        {
            "id": "smalltalk_10205_5",
            "desc": "同步后対話 2",
            "dlg": "宁在詢問我的工作是否繁重麼。我没怎么在意過。浮士德只会考慮保護対象的安全。"
        },
        {
            "id": "neglect_10205_1",
            "desc": "閑置",
            "dlg": "如果没有什么特別事情的話，請允許我去処理下一分巡察計劃。"
        },
        {
