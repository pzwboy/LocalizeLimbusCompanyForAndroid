    "dataList": [
        {
            "id": "battleTip_10903_1",
            "content": "由于父輩的命令，拇指子輩无法対良秀使用強力的攻撃。"
        },
        {
            "id": "battleTip_10903_2",
            "content": "應尽量避免譲同一位罪人与拇指子輩拼点。"
        },
        {
            "id": "battleTip_10903_3",
            "content": "在拇指子輩使用強力攻撃前，應確保能拼点勝過他的其他攻撃技能。"
        },
        {
            "id": "battleTip_10910_1",
            "content": "有時優先破坏会妨碍破坏果實部位的其他部位，或許会更加有利。"
        },
        {
            "id": "battleTip_10910_2",
            "content": "清晰了解每位罪人各自描准那个部位十分重要。"
        },
        {
            "id": "battleTip_10910_3",
            "content": "請確認所装備的E.G.O，嘗試以能劬獲取相應資源的人格組成隊伍并進行戦斗。"
        },
        {
            "id": "battleTip_10918_phase1_1",
            "content": "請准備好在与小指子輩強力技能拼点中獲勝的策略。"
        },
        {
            "id": "battleTip_10918_phase1_2",
            "content": "正確処理最危険的攻撃，遠比与所有技能都進行拼点重要。"
        },
        {
            "id": "battleTip_10918_phase2_1",
            "content": "除了拼点，還有其他弱化環指子輩強力攻撃的方法。"
        },
        {
            "id": "battleTip_10918_phase2_2",
            "content": "環指子輩的守備技能会対目標施加流血，攻撃需謹慎。"
        }
    ]
