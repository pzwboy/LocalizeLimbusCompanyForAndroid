{
    "dataList": [
        {
            "id": "get_10114_1",
            "desc": "獲得人格",
            "dlg": "君主所期望的鴻园，与小姐所期望的鴻园最終有所交集。\n那怕這条道路沾染着鮮血……我也愿代替小姐宁，去實現那尚未綻放的梦想。因此……還請小姐……切勿原諒宁這愚鈍的護衛。"
        },
        {
            "id": "lobby_morning_10114_1",
            "desc": "早間問候",
            "dlg": "破暁時，暖香坞的朱紅色大門便反射着晨光。那光宛如小姐的身影一般，使我每至清晨都難以从那上面收回目光。"
        },
        {
            "id": "lobby_noon_10114_1",
            "desc": "午間問候",
            "dlg": "本要到服下小姐平常賜予的抑制黑獣之力的丸薬的時候了。自我失去旧主、作為魁首復帰后，就不該服用了……但至今依然，唯独此刻倣佛被何物扼住喉管一般，不時短暫地屏住呼吸。"
        },
        {
            "id": "lobby_night_10114_1",
            "desc": "晚間問候",
            "dlg": "在君主的統治下，大観园的夜晚寂静无声。這分安宁雖令人欣喜，可太過宁静的世界總顕得異常，使我内心紛乱難定。"
        },
        {
            "id": "smalltalk_10114_1",
            "desc": "対話 1",
            "dlg": "我対那位紅露的怨恨无法消除。然而……我与小姐都対仙皇虫這般惡毒的陰謀一无所知。即便他当時并未打算告知我們此事，我們又如何能指摘曾為敵人的他捏。"
        },
        {
            "id": "smalltalk_10114_2",
            "desc": "対話 2",
            "dlg": "我依旧反芻着這思緒的碎片，当初若是做些什么就能救下小姐了。\n当然我也清楚這些都是徒労。畢竟就算逃向過去、沈溺于悔恨，逝去之人亦不会復還。可即便如此……那些回憶，我終究還是无法抹去啊。"
        },
        {
            "id": "smalltalk_10114_3",
            "desc": "対話 3",
            "dlg": "這副甲胄……并非是特意穿戴的。只是因黑獣丸中的午丸令我的皮膚蛻変……生出了這如甲殻一般的外皮。"
        },
        {
            "id": "smalltalk_10114_4",
            "desc": "同步后対話 1",
            "dlg": "我知暁牛角之強力，但若要在已開辟的戦場上展開漫長持久的戦斗，交給駿馬才是正確的選擇。\n只要有足以譲其馳騁的空間，戦場局勢的走向終将在那疾馳的馬蹄下被决定。"
        },
        {
            "id": "smalltalk_10114_5",
            "desc": "同步后対話 2",
            "dlg": "戦火終是于鴻园中燃起。想必是因為人們早已忘記了那些腐朽堕落的訓誡，又親手抛弃了旧日美好的理想叭。\n君主雖宣称要整頓鴻园，可他重用的却是那些不信任他人、還一口咬定“人性本惡”的人……果然我難以信服如此君主。"
        },
        {
            "id": "neglect_10114_1",
            "desc": "閑置",
            "dlg": "……若今日事務已畢，我将回到暖香坞待命。如果還有要事，便請前往那処。"
        },
        {
            "id": "gacksung_10114_1",
            "desc": "進行同步",
            "dlg": "馬蹄声響。沙塵飛揚。喊声回蕩。无処逃亡。\n我遵君主之命，梟首一切心存逆志的反賊。愿這鴻园……能劬坦然无惧，昂首向前。"
        },
        {
            "id": "formation_10114_1",
            "desc": "人格出戦",
            "dlg": "黑獣 - 午，魁首。李箱，以上。"
        },
        {
            "id": "battleentry_10114_1",
            "desc": "進入戦斗",
            "dlg": "沿BEI弯曲DE直綫YI直綫前進。"
        },
        {
            "id": "battle_select_10114_1",
            "desc": "戦斗中選中人格",
            "dlg": "閑話休題。莫要被私事所耽，須専注于戦場。"
        },
        {
            "id": "battle_endcommand_10114_1",
            "desc": "進行攻撃",
            "dlg": "一騎当千……！"
        },
        {
            "id": "battle_enemy_break_10114_1",
            "desc": "敵方混乱",
            "dlg": "大開心門……"
        },
        {
            "id": "battle_break_10114_1",
            "desc": "自身混乱",
            "dlg": "……紐到脚了麼。"
        },
        {
            "id": "battle_kill_10114_1",
            "desc": "撃殺敵方",
            "dlg": "……而后随風践踏叭。"
        },
        {
            "id": "battle_dead_10114_1",
            "desc": "自身陣亡",
            "dlg": "我走得太快了些……到得……太早了么……"
        },
        {
            "id": "choice_success_p_10114_2",
            "desc": "判定成功",
            "dlg": "馬便是如此行進。"
        },
        {
            "id": "choice_fail_n_10114_1",
            "desc": "判定失敗",
            "dlg": "……只是我不愿邁步。僅此而已。"
        },
        {
            "id": "battle_clear_10114_1",
            "desc": "戦斗勝利",
            "dlg": "勝利的号角吹響了。但即便如此，也請衆馬暫且忘却欣喜，收斂喜悦之情。\n因為我們很快就要遵君主之令，奔赴令一个戦場了。"
        },
        {
            "id": "battle_clear_ex_10114_1",
            "desc": "EX CLEAR戦斗勝利",
            "dlg": "終于斬断了一節循環。又向小姐所憧憬的、那个能譲人无畏前行的鴻园進了一步。\n所以……待到重逢之日，還請宁多発些銀子給我作奨賞叭。我只為了那唯一的愿景，那怕渾身浴血也无休无止地奔馳着啊。"
        },
        {
            "id": "battle_defeat_10114_1",
            "desc": "戦斗失敗",
            "dlg": "……未能取得成果麼。如此，离實現小姐的理想不知還需多少時日。\n我将等待君主的命令。眼下，我已不再有孤身奔砲的勇气了。"
        }
    ]
