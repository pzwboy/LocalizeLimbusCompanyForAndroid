{
    "dataList": [
        {
            "id": 0,
            "content": "飛呀，破碎的翅膀"
        },
        {
            "id": 1,
            "content": "我知道袮仍在我身旁"
        },
        {
            "id": 2,
            "content": "只需袮輕輕一推，我就能再次起飛"
        },
        {
            "id": 3,
            "content": "飛呀，破碎的翅膀"
        },
        {
            "id": 4,
            "content": "帯我前往自由之地"
        },
        {
            "id": 5,
            "content": "接近我們的“理想”"
        },
        {
            "id": 6,
            "content": "湿潤的双眼"
        },
        {
            "id": 7,
            "content": "曾經温柔的某人"
        },
        {
            "id": 8,
            "content": "我旁観逐漸腐朽不見的袮"
        },
        {
            "id": 9,
            "content": "鏡子説"
        },
        {
            "id": 10,
            "content": "我并未忘記希望"
        },
        {
            "id": 11,
            "content": "唔唔唔"
        },
        {
            "id": 12,
            "content": "能做袮喜歓做的事"
        },
        {
            "id": 13,
            "content": "難道還不劬麼？難道還不劬麼？"
        },
        {
            "id": 14,
            "content": "擁有天生的才能，完美的職位"
        },
        {
            "id": 15,
            "content": "難道還不劬麼？難道還不劬麼？"
        },
        {
            "id": 16,
            "content": "一次又一次"
        },
        {
            "id": 17,
            "content": "袮束縛了我，我束縛了我"
        },
        {
            "id": 18,
            "content": "我們一同把我釘在地上"
        },
        {
            "id": 19,
            "content": "土壤温暖我的身体"
        },
        {
            "id": 20,
            "content": "求袮死去叭，渺小的梦想"
        },
        {
            "id": 21,
            "content": "来殺尽我心中那朶朶山茶花呀"
        },
        {
            "id": 22,
            "content": "若能放弃，有多容易？"
        },
        {
            "id": 23,
            "content": "為何這双不听話的手非要伸向那些過于遥遠的梦？"
        },
        {
            "id": 24,
            "content": "憧憬普通的我這分飢渴是否“異常”？"
        },
        {
            "id": 25,
            "content": "飛呀，完美的翅膀"
        },
        {
            "id": 26,
            "content": "（再見，再見，再見）"
        },
        {
            "id": 27,
            "content": "袮至今為止到底藏在那里？"
        },
        {
            "id": 28,
            "content": "（再見，再見，再見）"
        },
        {
            "id": 29,
            "content": "帯我回到我們最初始的那个心境"
        },
        {
            "id": 30,
            "content": "飛呀，完美的翅膀"
        },
        {
            "id": 31,
            "content": "（再見，再見，再見）"
        },
        {
            "id": 32,
            "content": "為大家展現我的實力"
        },
        {
            "id": 33,
            "content": "（再見，再見，再見）"
        },
        {
            "id": 34,
            "content": "一次就劬，還請帮我實現"
        },
        {
            "id": 35,
            "content": "“以上”就是我最后的愿望"
        }
    ]
}