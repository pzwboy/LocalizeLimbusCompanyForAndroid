{
    "dataList": [
        {
            "id": 0,
            "content": "即使到了晚上，在人造光源下依然明亮的鴻园之夜。"
        },
        {
            "id": 1,
            "content": "孩子黄色的眼睛炯炯有神地閃爍着，俯視着眼前可惡的小偸。"
        },
        {
            "id": 2,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "袮那可笑的狂奔終于結束了麼。",
            "teller": "奥提斯"
        },
        {
            "id": 3,
            "teller": "小偸",
            "title": "？？？",
            "content": "雖然听説過卯很快……但這也……"
        },
        {
            "id": 4,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "竟然以為能用那么慢的步伐从兔子身辺逃走……真是愚蠢。",
            "teller": "奥提斯"
        },
        {
            "id": 5,
            "content": "从半路截走主公本應收到的重要物品，然后消失的小偸。"
        },
        {
            "id": 6,
            "content": "尽管小偸逃砲兩个小時后，孩子才接收到抓捕小偸的命令……"
        },
        {
            "id": 7,
            "content": "但這時間差就好像没有意義一般，孩子只用不到半个小時便追上了他。"
        },
        {
            "id": 8,
            "content": "雖然鴻园的后巷因為各種建筑而錯綜復雑，但対于每天都以鴻园為舞台展開暗斗的黑獣来説，應該已經対他的逃砲路綫了如指掌了叭。"
        },
        {
            "id": 9,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "“虫”没事叭。",
            "teller": "奥提斯"
        },
        {
            "id": 10,
            "content": "小偸手里蠕動着一条又長又肥的虫子。"
        },
        {
            "id": 11,
            "content": "尽管其光滑的表面、柔軟的身躯不自然地蠕動的様子已經劬恐怖的了……"
        },
        {
            "id": 12,
            "content": "但最可怕的，還属那个被称為“虫”的怪物的頭部。"
        },
        {
            "id": 13,
            "content": "雖然長得和人類一模一様，但它的皮膚蒼白松弛，凹陷的眼窩失去焦点，茫然地凝視着虚空，宛如一只恐怖的怪物。"
        },
        {
            "id": 14,
            "content": "尽管如此，小偸還是小心翼翼地用双手環抱着它，好像那是一件珍貴的宝物。"
        },
        {
            "id": 15,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "偸了用貴人所制成的虫，就算立即将袮斬首也不為過……",
            "teller": "奥提斯"
        },
        {
            "id": 16,
            "content": "在西部或南部等其他地区生活的人們看来，一条虫子能做什么……"
        },
        {
            "id": 17,
            "content": "但這个小偸拿着的虫，和一般的虫子可不一様。"
        },
        {
            "id": 18,
            "content": "這是一種特殊的虫子，放入体内后便能獲得成為其材料之人的記憶，"
        },
        {
            "content": "无論材料的貴賎，都会被認定為人而非物品的特殊的存在。"
        },
        {
            "id": 19,
            "content": "其中被小偸偸走的虫，是以知暁家族諸多秘辛的鴻园的尊貴人物為材料，錬制而成的貴重物品。"
        },
        {
            "id": 20,
            "content": "里面会以記憶的形式，記録着与孩子侍奉的主公相関的家族的各種信息……"
        },
        {
            "id": 21,
            "content": "如果敵対家族的候選人把“虫”拿到手并放進自己体内，那么孩子的主公瞬間就会被奪走家族的各種秘密。"
        },
        {
            "id": 22,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "我想听听袮貪圖那只虫的理由。",
            "teller": "奥提斯"
        },
        {
            "id": 23,
            "content": "尽管如此，孩子還是决定与其直接坎掉小偸的頭，不如問問情况。"
        },
        {
            "id": 24,
            "content": "孩子并没有懐有同情心。"
        },
        {
            "id": 25,
            "content": "只是因為孩子的主公希望如此。"
        },
        {
            "id": 26,
            "content": "是因為从孩子冷淡的語調中，領悟到了下達命令之人給予的机会麼？"
        },
        {
            "id": 27,
            "content": "小偸立即跪下，用悲傷的声音開始講述自己的故事。"
        },
        {
            "id": 28,
            "teller": "小偸",
            "title": "？？？",
            "content": "只、只是因為我需要銭啊。"
        },
        {
            "id": 29,
            "teller": "小偸",
            "title": "？？？",
            "content": "只、只要从其他家族那里拿到虫，就能得到一筆足劬安穏生活一輩子的財富。"
        },
        {
            "id": 30,
            "teller": "小偸",
            "title": "？？？",
            "content": "為了照顧生病的老母親，我別无選擇……"
        },
        {
            "id": 31,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "此乃幌言。要是黑獣連這个都察覚不到的話，怎么可能這么輕易就找到袮。",
            "teller": "奥提斯"
        },
        {
            "id": 32,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "生病的老母親……哈。袮老母早在三年前就没命了。",
            "teller": "奥提斯"
        },
        {
            "id": 33,
            "teller": "小偸",
            "title": "？？？",
            "content": "居然在那么短的時間里……"
        },
        {
            "id": 34,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "老實交代。",
            "teller": "奥提斯"
        },
        {
            "id": 35,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "主公伸給袮的救命稻草可并不長。",
            "teller": "奥提斯"
        },
        {
            "id": 36,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "如果无縁无故地説幌的話……",
            "teller": "奥提斯"
        },
        {
            "id": 37,
            "content": "面対孩子堅决的態度，小偸犹豫了半天才開口。"
        },
        {
            "id": 38,
            "teller": "小偸",
            "title": "？？？",
            "content": "……"
        },
        {
            "id": 39,
            "teller": "小偸",
            "title": "？？？",
            "content": "我再也不想成天提心吊胆，担心自己什么時候会被重構日淘汰了。"
        },
        {
            "id": 40,
            "content": "存在于鴻园的大部分建筑，每隔一段時間就会移動一次。"
        },
        {
            "id": 41,
            "content": "那是根据各自所擁有的財産，重新分配空間的過程。"
        },
        {
            "id": 42,
            "content": "窮人居住的空間会越来越小，在本應成為休息場所的家里也无法安心休息。"
        },
        {
            "id": 43,
            "content": "雖説是令人惋惜的処境……但対于作為黑獣的孩子来説，這个故事并不能引起他的共鳴。"
        },
        {
            "id": 44,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "是因為財迷心巧才這么做的麼。",
            "teller": "奥提斯"
        },
        {
            "id": 45,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "如果是這種程度的話……我們要聊的話題就到此為止了。",
            "teller": "奥提斯"
        },
        {
            "id": 46,
            "teller": "小偸",
            "title": "？？？",
            "content": "如、如果袮靠近我，或者譲我看到袮的脚有変形的迹象的話……我就馬上把這个虫放進自己的耳朶里！"
        },
        {
            "id": 47,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "……急着送死麼。這不是袮能承受的記憶。何况……",
            "teller": "奥提斯"
        },
        {
            "id": 48,
            "teller": "小偸",
            "title": "？？？",
            "content": "等、等一下！！！"
        },
        {
            "id": 49,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "不。没必要再説了。",
            "teller": "奥提斯"
        },
        {
            "id": 50,
            "content": "小偸還没説完，孩子背上的剣就開始閃爍起凶惡的光芒。"
        },
        {
            "id": 51,
            "content": "用Q公司的技術刻在這柄剣上的奇異文字，只有在満足特定条件時才能発揮真正的力量。"
        },
        {
            "id": 52,
            "content": "在這次任務中，孩子能使用這分力量的条件，是偸走“虫”的人拒絶了主公的仁慈。"
        },
        {
            "id": 53,
            "content": "拿着剣的孩子的脚，瞬間変成了像兔子一様的逆関節，做好了冲向小偸的准備……"
        },
        {
            "id": 54,
            "content": "預感到未来的小偸尽管明知是徒労，却仍用尽全力地向后倒去。"
        },
        {
            "id": 55,
            "teller": "小偸",
            "title": "？？？",
            "content": "咳額額……媽的！"
        },
        {
            "id": 56,
            "content": "作為最后的手段，小偸慌忙将虫放進了耳朶里……"
        },
        {
            "id": 57,
            "teller": "小偸",
            "title": "？？？",
            "content": "咯啊……"
        },
        {
            "id": 58,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "即使把虫放入体内，如果立即死亡的話……在体内的虫被同化之前，都可以完好无損地重新取出。",
            "teller": "奥提斯"
        },
        {
            "id": 59,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "袮忽略了這一点。",
            "teller": "奥提斯"
        },
        {
            "id": 60,
            "content": "孩子的剣冲出得太快，小偸半声惨叫噎在喉頭時便喪命了。"
        },
        {
            "id": 61,
            "content": "再過一会儿，“虫”就会和小偸的身体融為一体……在満足制作“虫”時刻下的条件之前，用任何手段都无法取出……"
        },
        {
            "id": 62,
            "content": "既然在被同化之前取了命，孩子就可以輕松地找回虫了。"
        },
        {
            "id": 63,
            "model": "오티스",
            "title": "黑獣 - 卯",
            "content": "下一个任務是……",
            "teller": "奥提斯"
